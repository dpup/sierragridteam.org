---
/**
 * EmergencyBanner — the site-wide alarm band (in BaseLayout, every page). Renders
 * nothing on calm days; when a life-safety hazard is active (an active evacuation or
 * wildfire — both area-scoped) it shows a slim orange band naming the hazard, linking to the
 * Live Feed (which carries the authoritative evacuation map).
 * Orange here is a sanctioned genuine-alert use. Client-only (no baked data): SSR renders
 * the band hidden + empty, and a client island checks the place summary + wildfire layer on
 * load + every 90s and shows/fills it — never trusting the region-wide rollup severity, and only writing to the
 * role="alert" region when the state actually changes (so it doesn't re-announce each poll).
 */
import { HAZARD_AREA } from '@lib/hazards';
import { GRID_API_BASE } from '@lib/grid';
import { emergencyBanner as copy } from '@config/content';
---

<aside
  class="ebanner"
  data-ebanner
  data-area={HAZARD_AREA}
  data-api-base={GRID_API_BASE}
  role="alert"
  aria-label="Emergency alert"
  hidden
>
  <div class="ebanner__inner">
    <p class="ebanner__text">
      <span class="ebanner__icon" aria-hidden="true">▲</span>
      <strong class="ebanner__label" data-ebanner-label></strong>
      <span data-ebanner-headline></span>
    </p>
    <span class="ebanner__actions">
      <a class="ebanner__link" href="/live">{copy.feedLabel} &rarr;</a>
    </span>
  </div>
</aside>

<script>
  const el = document.querySelector<HTMLElement>('[data-ebanner]');
  if (el) {
    const base = el.dataset.apiBase ?? 'https://data.sierragridteam.org/api/v1';
    const area = el.dataset.area ?? 'ebbetts-pass';
    let lastSig = '';
    const set = (sel: string, text: string) => {
      const t = el.querySelector<HTMLElement>(sel);
      if (t) t.textContent = text;
    };
    const refresh = async () => {
      try {
        const [sumRes, fireRes] = await Promise.all([
          fetch(`${base}/places/${area}/summary`, { headers: { accept: 'application/json' } }),
          fetch(`${base}/places/${area}/map/wildfire.geojson`, {
            headers: { accept: 'application/json' },
          }),
        ]);
        if (!sumRes.ok || !fireRes.ok) return;
        const s = (await sumRes.json()) as {
          summary?: {
            activeEvacuations?: number | null;
            topEvents?: { layer: string; headline: string }[];
          };
        };
        const fire = (await fireRes.json()) as {
          features?: { properties?: { headline?: string } }[];
        };
        const sum = s.summary ?? {};
        const events = sum.topEvents ?? [];
        const fireFeatures = fire.features ?? [];
        const hasEvac = (sum.activeEvacuations ?? 0) > 0;
        // Read the authoritative, place-scoped wildfire MAP layer for this life-safety band,
        // rather than a summary rollup count.
        const hasWildfire = fireFeatures.length > 0;

        // Life-safety bar ONLY: evacuation or wildfire (both area-scoped). The summary's
        // region-wide highestSeverity / road / weather headlines are never trusted —
        // they can describe an out-of-area event (the life-safety-only banner contract).
        const active = hasEvac || hasWildfire;
        const headline =
          (hasEvac
            ? events.find((h) => h.layer === 'EVACUATION')?.headline
            : fireFeatures[0]?.properties?.headline) ??
          (hasEvac
            ? 'Active evacuation in the service area'
            : 'Active wildfire near the foothills');
        const label = hasEvac ? 'Evacuation' : 'Active Wildfire';

        // Only touch the DOM when something actually changed — the role="alert" live
        // region must not re-announce on every 90s poll during a sustained emergency.
        const sig = `${active}|${label}|${headline}|${hasEvac}`;
        if (sig === lastSig) return;
        lastSig = sig;

        if (!active) {
          el.hidden = true;
          return;
        }
        set('[data-ebanner-headline]', headline);
        set('[data-ebanner-label]', label);
        el.hidden = false;
      } catch {
        /* keep the SSR banner state */
      }
    };
    refresh();
    setInterval(refresh, 90_000);
  }
</script>

<style>
  .ebanner {
    background: var(--signal-orange);
    color: var(--surface-page);
  }
  .ebanner[hidden] {
    display: none;
  }
  .ebanner__inner {
    max-width: var(--container-wide);
    margin-inline: auto;
    padding: var(--space-3) var(--gutter);
    display: flex;
    align-items: center;
    gap: var(--space-3) var(--space-5);
    flex-wrap: wrap;
  }
  /* Inline within the text so it never wraps onto its own line on narrow screens —
     it sits as the leading glyph of the message and shrinks/wraps with it. */
  .ebanner__icon {
    margin-right: var(--space-2);
  }
  .ebanner__text {
    flex: 1 1 auto;
    min-width: 0;
    font-family: var(--font-ui);
    font-size: var(--fs-small);
    line-height: var(--lh-body);
  }
  .ebanner__label {
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    margin-right: var(--space-2);
  }
  .ebanner__actions {
    flex-shrink: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-4);
  }
  .ebanner__link {
    color: var(--surface-page);
    font-family: var(--font-ui);
    font-size: var(--fs-label);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    text-decoration: underline;
    text-underline-offset: 3px;
    white-space: nowrap;
  }
  .ebanner__link:hover {
    color: var(--surface-page);
    text-decoration: none;
  }
</style>
