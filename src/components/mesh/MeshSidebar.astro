---
/**
 * MeshSidebar — the /mesh info panel: a short description of the live mesh map.
 * Pure content; the collapse behavior + layout live in the page (src/pages/mesh.astro).
 */
import Kicker from '../Kicker.astro';
import { mesh } from '@config/content';
---

<div class="mesh-sidebar">
  <header class="mesh-sidebar__head">
    <Kicker>{mesh.kicker}</Kicker>
    <h1 class="mesh-sidebar__title">{mesh.title}</h1>
    <p class="mesh-sidebar__intro">{mesh.intro}</p>
  </header>
</div>

<style>
  .mesh-sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    padding: var(--space-7) var(--space-6);
  }

  .mesh-sidebar__title {
    margin-top: var(--space-3);
    font-size: var(--fs-h3);
  }

  .mesh-sidebar__intro {
    margin-top: var(--space-3);
    font-size: var(--fs-small);
    line-height: var(--lh-body);
    color: var(--ink-body);
  }
</style>
