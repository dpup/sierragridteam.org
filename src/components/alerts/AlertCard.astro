---
/**
 * AlertCard — one severity-coded, expandable alert (weather or road incident).
 * Uses a native <details>/<summary> for accessible expand/collapse. Severity maps
 * to the accent: Extreme/Severe → orange (risk), Moderate → brass, Minor → green.
 * Orange is used ONLY for genuine high-severity alerts.
 */
interface Props {
  severity?: string;
  title: string;
  summary?: string;
  detail?: string;
  meta?: string;
  open?: boolean;
}

const { severity = '', title, summary, detail, meta, open = false } = Astro.props;

function accentFor(sev: string): 'orange' | 'brass' | 'green' {
  const s = sev.toLowerCase();
  if (s.includes('extreme') || s.includes('severe')) return 'orange';
  if (s.includes('moderate') || s.includes('warning')) return 'brass';
  return 'green';
}
const accent = accentFor(severity);
---

<details class:list={['alert-card', `alert-card--${accent}`]} open={open}>
  <summary class="alert-card__summary">
    <span class="alert-card__bar" aria-hidden="true"></span>
    <span class="alert-card__heading">
      {severity && <span class="alert-card__sev">{severity}</span>}
      <span class="alert-card__title">{title}</span>
      {summary && <span class="alert-card__excerpt">{summary}</span>}
    </span>
    <span class="alert-card__chevron" aria-hidden="true"></span>
  </summary>
  <div class="alert-card__body">
    {detail && <p class="alert-card__detail">{detail}</p>}
    {meta && <p class="alert-card__meta">{meta}</p>}
  </div>
</details>

<style>
  .alert-card {
    background: var(--surface-card);
    border: var(--border);
    border-left-width: 3px;
    border-radius: var(--radius);
  }
  .alert-card--orange {
    border-left-color: var(--signal-orange);
  }
  .alert-card--brass {
    border-left-color: var(--brand-brass);
  }
  .alert-card--green {
    border-left-color: var(--brand-green);
  }

  .alert-card__summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-5);
  }
  .alert-card__summary::-webkit-details-marker {
    display: none;
  }

  .alert-card__heading {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .alert-card__sev {
    font-family: var(--font-ui);
    font-size: var(--fs-micro);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
  }
  .alert-card--orange .alert-card__sev {
    color: var(--signal-orange-text);
  }
  .alert-card--brass .alert-card__sev {
    color: var(--brand-brass-text);
  }
  .alert-card--green .alert-card__sev {
    color: var(--brand-green);
  }

  .alert-card__title {
    font-family: var(--font-display);
    font-size: var(--fs-body);
    font-weight: var(--fw-medium);
    color: var(--ink-strong);
  }
  .alert-card__excerpt {
    font-size: var(--fs-small);
    color: var(--ink-secondary);
  }

  .alert-card__chevron {
    margin-top: 6px;
    width: 7px;
    height: 7px;
    border-right: 2px solid var(--ink-muted);
    border-bottom: 2px solid var(--ink-muted);
    transform: rotate(45deg);
    transition: transform var(--transition);
    flex-shrink: 0;
  }
  .alert-card[open] .alert-card__chevron {
    transform: rotate(-135deg);
  }

  .alert-card__body {
    padding: 0 var(--space-5) var(--space-5) calc(var(--space-5) + var(--space-3));
  }
  .alert-card__detail {
    font-size: var(--fs-small);
    line-height: var(--lh-body);
    color: var(--ink-body);
  }
  .alert-card__meta {
    margin-top: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    color: var(--ink-muted);
  }
</style>
