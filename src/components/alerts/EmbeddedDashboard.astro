---
/**
 * EmbeddedDashboard — an external dashboard (CHP CAD) framed in a restrained
 * "browser window" chrome: a title bar with window dots, the source URL, and an
 * open-in-new-tab link, then the iframe. If the embed is blocked, the link is
 * the fallback. Window dots are muted/on-brand, not playful.
 */
interface Props {
  src: string;
  title: string;
  /** Display URL shown in the faux address bar. */
  urlLabel: string;
}
const { src, title, urlLabel } = Astro.props;
---

<figure class="dashboard">
  <div class="dashboard__chrome">
    <span class="dashboard__dots" aria-hidden="true">
      <span></span><span></span><span></span>
    </span>
    <span class="dashboard__url" aria-hidden="true">{urlLabel}</span>
    <a class="dashboard__open" href={src} target="_blank" rel="noopener external">
      Open&nbsp;&nbsp;&#8599;
    </a>
  </div>
  <div class="dashboard__frame-wrap">
    <iframe
      class="dashboard__frame"
      src={src}
      title={title}
      loading="lazy"
      referrerpolicy="no-referrer"
      sandbox="allow-scripts allow-same-origin allow-popups allow-forms"></iframe>
    <p class="dashboard__fallback">
      If the dashboard does not load here, <a href={src} target="_blank" rel="noopener external"
        >open it directly</a
      >.
    </p>
  </div>
  <figcaption class="sr-only">{title}</figcaption>
</figure>

<style>
  .dashboard {
    margin: 0;
    border: var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--surface-card);
  }

  .dashboard__chrome {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-3) var(--space-4);
    background: var(--surface-banner);
    border-bottom: var(--border);
  }

  .dashboard__dots {
    display: inline-flex;
    gap: 6px;
    flex-shrink: 0;
  }
  .dashboard__dots span {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--line);
  }

  .dashboard__url {
    flex: 1;
    padding: var(--space-1) var(--space-3);
    background: var(--surface-page);
    border: var(--border);
    border-radius: var(--radius);
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    color: var(--ink-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .dashboard__open {
    flex-shrink: 0;
    font-family: var(--font-ui);
    font-size: var(--fs-label);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--brand-green);
  }

  .dashboard__frame-wrap {
    position: relative;
  }
  .dashboard__frame {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 520px;
    border: 0;
    background: var(--surface-page);
  }
  /* Fallback sits behind the iframe; visible only if the embed fails to paint. */
  .dashboard__fallback {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-6);
    text-align: center;
    font-size: var(--fs-small);
    color: var(--ink-secondary);
  }
</style>
