---
/**
 * AlertsFeed — active weather alerts for the service area. SSR from the
 * build-time snapshot; a client island refreshes every 5 minutes and silently
 * keeps the SSR list on failure (incl. the current CORS block, FR-1). A note
 * flags that NWS zone-specific alerts (CAZ064/065/258/259) are pending (FR-2).
 */
import AlertCard from './AlertCard.astro';
import Callout from '../Callout.astro';
import { ERSN_API_BASE, type AlertsResponse } from '@lib/ersn';
import { alerts as copy } from '@config/content';

interface Props {
  alerts: AlertsResponse | null;
}
const { alerts } = Astro.props;
const list = alerts?.alerts ?? [];
---

<section class="feed" aria-labelledby="feed-title" data-feed data-api-base={ERSN_API_BASE}>
  <div class="feed__head">
    <h2 id="feed-title" class="feed__title">{copy.feedHeading}</h2>
    <p class="feed__synced" data-feed-synced>Auto-refreshes every 5 minutes</p>
  </div>

  <div class="feed__list" data-alerts-list>
    {
      list.length === 0 ? (
        <p class="feed__empty" data-alerts-empty>
          {copy.emptyState}
        </p>
      ) : (
        list.map((a) => (
          <AlertCard
            severity={a.severity}
            title={a.event ?? 'Weather alert'}
            summary={a.headline}
            detail={a.description}
            meta={a.sender}
          />
        ))
      )
    }
  </div>

  <Callout accent="brass" heading="Coverage note" class="feed__note">
    Zone-specific National Weather Service alerts (CAZ064 / CAZ065 / CAZ258 / CAZ259) are not yet
    available from the data feed; this list reflects the regional weather feed. NWS-zone integration
    is tracked as a feature request.
  </Callout>
</section>

<script>
  const REFRESH_MS = 5 * 60 * 1000;
  const root = document.querySelector<HTMLElement>('[data-feed]');
  if (root) {
    const base = root.dataset.apiBase ?? 'https://info.ersn.net/api/v1';
    const listEl = root.querySelector<HTMLElement>('[data-alerts-list]');
    const syncedEl = root.querySelector<HTMLElement>('[data-feed-synced]');

    const esc = (s: string) =>
      s.replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' })[c]!);

    const accentFor = (sev: string) => {
      const s = (sev || '').toLowerCase();
      if (s.includes('extreme') || s.includes('severe')) return 'orange';
      if (s.includes('moderate') || s.includes('warning')) return 'brass';
      return 'green';
    };

    type Alert = {
      event?: string;
      severity?: string;
      headline?: string;
      description?: string;
      sender?: string;
    };

    const render = (items: Alert[]) => {
      if (!listEl) return;
      if (items.length === 0) {
        listEl.innerHTML = `<p class="feed__empty">No active weather alerts for the service area right now.</p>`;
        return;
      }
      listEl.innerHTML = items
        .map((a) => {
          const accent = accentFor(a.severity ?? '');
          return `<details class="alert-card alert-card--${accent}">
            <summary class="alert-card__summary">
              <span class="alert-card__bar" aria-hidden="true"></span>
              <span class="alert-card__heading">
                ${a.severity ? `<span class="alert-card__sev">${esc(a.severity)}</span>` : ''}
                <span class="alert-card__title">${esc(a.event ?? 'Weather alert')}</span>
                ${a.headline ? `<span class="alert-card__excerpt">${esc(a.headline)}</span>` : ''}
              </span>
              <span class="alert-card__chevron" aria-hidden="true"></span>
            </summary>
            <div class="alert-card__body">
              ${a.description ? `<p class="alert-card__detail">${esc(a.description)}</p>` : ''}
              ${a.sender ? `<p class="alert-card__meta">${esc(a.sender)}</p>` : ''}
            </div>
          </details>`;
        })
        .join('');
    };

    const refresh = async () => {
      try {
        const res = await fetch(`${base}/weather/alerts`, {
          headers: { accept: 'application/json' },
        });
        if (!res.ok) return;
        const data = (await res.json()) as { alerts?: Alert[]; lastUpdated?: string };
        render(data.alerts ?? []);
        if (syncedEl) {
          const t = new Intl.DateTimeFormat('en-GB', {
            timeZone: 'America/Los_Angeles',
            hour: '2-digit',
            minute: '2-digit',
            hour12: false,
          }).format(new Date());
          syncedEl.textContent = `Last checked ${t} PT`;
        }
      } catch {
        /* keep the SSR list */
      }
    };

    refresh();
    setInterval(refresh, REFRESH_MS);
  }
</script>

<style>
  .feed__head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-3);
    margin-bottom: var(--space-5);
  }
  .feed__title {
    font-size: var(--fs-h3);
  }
  .feed__synced {
    font-family: var(--font-ui);
    font-size: var(--fs-label);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--ink-muted);
  }

  @media (max-width: 520px) {
    .feed__head {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-2);
    }
  }

  .feed__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .feed__empty {
    padding: var(--space-6);
    background: var(--surface-card);
    border: var(--border);
    border-radius: var(--radius);
    font-size: var(--fs-small);
    color: var(--ink-secondary);
    text-align: center;
  }

  .feed__note {
    margin-top: var(--space-5);
  }
</style>
