---
/**
 * RoadConditions — live road status for the Highway 4 corridor from the
 * info.ersn.net roads feed (the most complete live data the feed provides).
 * Status maps to a tone: OPEN → ok, CLOSED → alarm, restricted/chain → elevated.
 */
import { kmToMi } from '@lib/units';
import type { RoadsResponse } from '@lib/ersn';

interface Props {
  roads: RoadsResponse | null;
}
const { roads } = Astro.props;
const list = roads?.roads ?? [];

function tone(status: string, chain: string): 'ok' | 'alarm' | 'elevated' {
  const s = status.toUpperCase();
  if (s.includes('CLOSED')) return 'alarm';
  if (s !== 'OPEN' || (chain && chain.toUpperCase() !== 'NONE')) return 'elevated';
  return 'ok';
}
const titleCase = (s: string) =>
  s.toLowerCase().replace(/\b\w/g, (c) => c.toUpperCase()).replace(/_/g, ' ');
---

<div class="roads">
  {
    list.map((r) => {
      const t = tone(r.status, r.chainControl);
      const incidents = r.alerts ?? [];
      return (
        <article class:list={['road', `road--${t}`]}>
          <header class="road__head">
            <div>
              <span class="road__name">{r.name}</span>
              <span class="road__section">{r.section}</span>
            </div>
            <span class:list={['road__status', `road__status--${t}`]}>
              <span class="road__dot" aria-hidden="true" />
              {titleCase(r.status)}
            </span>
          </header>

          <dl class="road__metrics">
            <div>
              <dt>Travel</dt>
              <dd>{r.durationMinutes} min</dd>
            </div>
            <div>
              <dt>Distance</dt>
              <dd>{kmToMi(r.distanceKm)} mi</dd>
            </div>
            <div>
              <dt>Delay</dt>
              <dd>{r.delayMinutes > 0 ? `+${r.delayMinutes} min` : 'None'}</dd>
            </div>
            <div>
              <dt>Chains</dt>
              <dd>{titleCase(r.chainControl || 'None')}</dd>
            </div>
          </dl>

          {incidents.length > 0 && (
            <ul class="road__incidents">
              {incidents.map((a) => (
                <li class="road__incident">
                  {a.condensedSummary || a.description || titleCase(a.type)}
                </li>
              ))}
            </ul>
          )}
        </article>
      );
    })
  }
</div>

<style>
  .roads {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--space-4);
  }

  .road {
    background: var(--surface-card);
    border: var(--border);
    border-radius: var(--radius);
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .road__head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-3);
  }
  .road__name {
    display: block;
    font-family: var(--font-display);
    font-size: var(--fs-body);
    font-weight: var(--fw-medium);
    color: var(--ink-strong);
  }
  .road__section {
    display: block;
    font-family: var(--font-ui);
    font-size: var(--fs-small);
    color: var(--ink-secondary);
  }

  .road__status {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    flex-shrink: 0;
    font-family: var(--font-ui);
    font-size: var(--fs-label);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
  }
  .road__status--ok {
    color: var(--brand-green);
  }
  .road__status--elevated {
    color: var(--brand-brass-text);
  }
  .road__status--alarm {
    color: var(--signal-orange-text);
  }
  .road__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: currentcolor;
  }

  .road__metrics {
    margin: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-3);
  }
  .road__metrics dt {
    font-family: var(--font-ui);
    font-size: var(--fs-micro);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--ink-muted);
  }
  .road__metrics dd {
    margin: var(--space-1) 0 0;
    font-family: var(--font-mono);
    font-size: var(--fs-small);
    color: var(--ink-strong);
  }

  .road__incidents {
    list-style: none;
    margin: 0;
    padding: var(--space-4) 0 0;
    border-top: var(--border-soft);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .road__incident {
    position: relative;
    padding-left: var(--space-4);
    font-size: var(--fs-small);
    line-height: var(--lh-body);
    color: var(--ink-body);
  }
  .road__incident::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 6px;
    height: 6px;
    background: var(--brand-brass);
  }

  @media (max-width: 420px) {
    .road__metrics {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
