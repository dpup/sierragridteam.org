---
/**
 * Incidents — region-wide CHP/Caltrans dispatch incidents from
 * info.ersn.net `/incidents/{area}` (FR-7). The page splits the feed into incidents
 * inside the foothill service area vs the wider Mother Lode region (see
 * splitIncidents in src/lib/ersn.ts); this component renders service-area incidents
 * first and tucks the wider region into a native <details> disclosure. SSR-only from
 * the build-time snapshot — no faked data; an empty feed shows an honest note.
 *
 * Severity → accent: CRITICAL → orange (risk), WARNING → brass, INFO → green.
 * Orange is used ONLY for genuine high-severity (CRITICAL) incidents.
 */
import type { Incident } from '@lib/ersn';

interface Props {
  inArea: Incident[];
  wider: Incident[];
}
const { inArea, wider } = Astro.props;

const tone = (sev: string): 'alarm' | 'elevated' | 'ok' => {
  const s = (sev || '').toUpperCase();
  if (s === 'CRITICAL') return 'alarm';
  if (s === 'WARNING') return 'elevated';
  return 'ok';
};
const titleCase = (s: string) => (s || '').toLowerCase().replace(/\b\w/g, (c) => c.toUpperCase());
---

{
  inArea.length === 0 && wider.length === 0 ? (
    <p class="incidents__empty">No active CHP or Caltrans incidents in the region right now.</p>
  ) : (
    <div class="incidents">
      {inArea.length > 0 ? (
        <ul class="incidents__list">
          {inArea.map((i) => (
            <li class:list={['incident', `incident--${tone(i.severity)}`]}>
              <span class="incident__body">
                <span class="incident__desc">{i.description}</span>
                <span class="incident__route">{i.locationDescription}</span>
              </span>
              <span class="incident__tags">
                <span class="incident__sev">{titleCase(i.severity)}</span>
                {i.type?.toUpperCase() === 'CLOSURE' && <span class="incident__type">Closure</span>}
              </span>
            </li>
          ))}
        </ul>
      ) : (
        <p class="incidents__none">
          No incidents within the Calaveras &amp; Tuolumne service area right now.
        </p>
      )}

      {wider.length > 0 && (
        <details class="incidents__wider">
          <summary class="incidents__widersummary">
            <span class="incidents__widerlabel">Wider Mother Lode region</span>
            <span class="incidents__widercount">{wider.length}</span>
            <span class="incidents__chevron" aria-hidden="true" />
          </summary>
          <ul class="incidents__list incidents__list--wider">
            {wider.map((i) => (
              <li class:list={['incident', `incident--${tone(i.severity)}`]}>
                <span class="incident__body">
                  <span class="incident__desc">{i.description}</span>
                  <span class="incident__route">{i.locationDescription}</span>
                </span>
                <span class="incident__tags">
                  <span class="incident__sev">{titleCase(i.severity)}</span>
                  {i.type?.toUpperCase() === 'CLOSURE' && (
                    <span class="incident__type">Closure</span>
                  )}
                </span>
              </li>
            ))}
          </ul>
        </details>
      )}
    </div>
  )
}

<style>
  .incidents {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .incidents__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .incident {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    background: var(--surface-card);
    border: var(--border);
    border-left-width: 3px;
    border-radius: var(--radius);
    padding: var(--space-4) var(--space-5);
  }
  .incident--alarm {
    border-left-color: var(--signal-orange);
  }
  .incident--elevated {
    border-left-color: var(--brand-brass);
  }
  .incident--ok {
    border-left-color: var(--brand-green);
  }

  .incident__body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    min-width: 0;
  }
  .incident__desc {
    font-family: var(--font-display);
    font-size: var(--fs-body);
    font-weight: var(--fw-medium);
    color: var(--ink-strong);
  }
  .incident__route {
    font-size: var(--fs-small);
    color: var(--ink-secondary);
  }

  .incident__tags {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--space-1);
    text-align: right;
  }
  .incident__sev {
    font-family: var(--font-ui);
    font-size: var(--fs-micro);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
  }
  .incident--alarm .incident__sev {
    color: var(--signal-orange-text);
  }
  .incident--elevated .incident__sev {
    color: var(--brand-brass-text);
  }
  .incident--ok .incident__sev {
    color: var(--brand-green);
  }
  .incident__type {
    font-family: var(--font-ui);
    font-size: var(--fs-micro);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--ink-muted);
  }

  .incidents__empty,
  .incidents__none {
    padding: var(--space-6);
    background: var(--surface-card);
    border: var(--border);
    border-radius: var(--radius);
    font-size: var(--fs-small);
    color: var(--ink-secondary);
    text-align: center;
  }
  .incidents__none {
    padding: var(--space-5);
    text-align: left;
  }

  /* Collapsible "wider region" — native <details>, keyboard-operable. */
  .incidents__wider {
    border-top: var(--border-soft);
    padding-top: var(--space-5);
  }
  .incidents__widersummary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding-block: var(--space-1);
  }
  .incidents__widersummary::-webkit-details-marker {
    display: none;
  }
  .incidents__widerlabel {
    font-family: var(--font-ui);
    font-size: var(--fs-label);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--ink-body);
  }
  .incidents__widercount {
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    color: var(--ink-muted);
    border: var(--border);
    border-radius: var(--radius);
    padding: 1px var(--space-2);
  }
  .incidents__chevron {
    width: 7px;
    height: 7px;
    margin-left: auto;
    border-right: 2px solid var(--ink-muted);
    border-bottom: 2px solid var(--ink-muted);
    transform: rotate(45deg);
    transition: transform var(--transition);
  }
  .incidents__wider[open] .incidents__chevron {
    transform: rotate(-135deg);
  }
  .incidents__list--wider {
    margin-top: var(--space-4);
  }

  @media (prefers-reduced-motion: reduce) {
    .incidents__chevron {
      transition: none;
    }
  }

  @media (max-width: 480px) {
    .incident {
      flex-direction: column;
      gap: var(--space-2);
    }
    .incident__tags {
      flex-direction: row;
      align-items: center;
      text-align: left;
      gap: var(--space-3);
    }
  }
</style>
