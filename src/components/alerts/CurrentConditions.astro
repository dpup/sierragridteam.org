---
/**
 * CurrentConditions — a compact current-conditions strip for every town the
 * info.ersn.net weather feed covers (Hwy 4 + Hwy 49/108 towns, FR-4). SSR from the
 * build-time snapshot; metric values are converted to imperial for the US audience
 * via src/lib/units.ts. Renders nothing if the feed has no weather (honest: no faked
 * conditions).
 */
import { cToF, kmhToMph, degreesToCompass } from '@lib/units';
import type { WeatherResponse } from '@lib/ersn';

interface Props {
  weather: WeatherResponse | null;
}
const { weather } = Astro.props;
const towns = weather?.weatherData ?? [];

const shortName = (name: string) => name.replace(/,\s*CA$/i, '');
const titleCase = (s: string) => s.replace(/\b\w/g, (c) => c.toUpperCase());
const windLabel = (kmh: number, deg: number) =>
  kmhToMph(kmh) <= 1 ? 'Calm' : `${kmhToMph(kmh)} mph ${degreesToCompass(deg)}`;
---

{
  towns.length > 0 && (
    <ul class="conditions">
      {towns.map((w) => (
        <li class="condition">
          <span class="condition__town">{shortName(w.locationName)}</span>
          <span class="condition__temp">{cToF(w.temperatureCelsius)}&deg;F</span>
          <span class="condition__sky">{titleCase(w.weatherDescription)}</span>
          <span class="condition__wind">{windLabel(w.windSpeedKmh, w.windDirectionDegrees)}</span>
        </li>
      ))}
    </ul>
  )
}

<style>
  .conditions {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: var(--space-3);
  }

  .condition {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-4) var(--space-5);
    background: var(--surface-card);
    border: var(--border);
    border-radius: var(--radius);
  }

  .condition__town {
    font-family: var(--font-ui);
    font-size: var(--fs-micro);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--ink-muted);
  }
  .condition__temp {
    font-family: var(--font-mono);
    font-size: var(--fs-h3);
    color: var(--ink-strong);
    line-height: 1.1;
  }
  .condition__sky {
    font-size: var(--fs-small);
    color: var(--ink-body);
  }
  .condition__wind {
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    color: var(--ink-secondary);
  }
</style>
