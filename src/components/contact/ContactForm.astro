---
/**
 * ContactForm — a mailto-based volunteer/contact form (no backend).
 * Works WITHOUT JavaScript (native mailto form submission); JS enhances it to
 * build a structured subject + body. The Ham call-sign field is clearly optional.
 */
import Button from '../Button.astro';
import { site, externalLinks } from '@config/site';
import { contact } from '@config/content';

const roleOptions = contact.roles.map((r) => r.name);
---

<form
  class="cform"
  data-contact-form
  action={`mailto:${site.email}`}
  method="post"
  enctype="text/plain"
  data-email={site.email}
>
  <p class="cform__intro">{contact.formIntro}</p>

  <div class="cform__row">
    <div class="cform__field">
      <label for="cf-name">Name <span class="cform__req" aria-hidden="true">*</span></label>
      <input id="cf-name" name="name" type="text" required autocomplete="name" />
    </div>
    <div class="cform__field">
      <label for="cf-email">Email <span class="cform__req" aria-hidden="true">*</span></label>
      <input id="cf-email" name="email" type="email" required autocomplete="email" />
    </div>
  </div>

  <div class="cform__row">
    <div class="cform__field">
      <label for="cf-callsign">
        Ham call sign <span class="cform__optional">(optional)</span>
      </label>
      <input
        id="cf-callsign"
        name="callsign"
        type="text"
        autocomplete="off"
        spellcheck="false"
        aria-describedby="cf-callsign-help"
      />
      <p id="cf-callsign-help" class="cform__help">If you hold an amateur radio license.</p>
    </div>
    <div class="cform__field">
      <label for="cf-role">Area of interest <span class="cform__optional">(optional)</span></label>
      <select id="cf-role" name="role">
        <option value="">No preference</option>
        {roleOptions.map((r) => <option value={r}>{r}</option>)}
      </select>
    </div>
  </div>

  <div class="cform__field">
    <label for="cf-message"
      >How would you like to help? <span class="cform__req" aria-hidden="true">*</span></label
    >
    <textarea id="cf-message" name="message" rows="5" required></textarea>
  </div>

  <div class="cform__actions">
    <Button variant="primary" type="submit" arrow>Send via email</Button>
    <p class="cform__fallback">
      Prefer to write directly? Email
      <a href={`mailto:${site.email}`}>{site.email}</a>.
    </p>
  </div>
</form>

<script>
  const form = document.querySelector<HTMLFormElement>('[data-contact-form]');
  if (form) {
    const email = form.dataset.email ?? '';
    form.addEventListener('submit', (e) => {
      // Enhance: build a structured mailto so the email client opens pre-filled.
      e.preventDefault();
      const data = new FormData(form);
      const get = (k: string) => String(data.get(k) ?? '').trim();
      const name = get('name');
      const subject = `Volunteer interest — ${name || 'S.I.E.R.R.A website'}`;
      const bodyLines = [
        `Name: ${name}`,
        `Email: ${get('email')}`,
        `Ham call sign: ${get('callsign') || '—'}`,
        `Area of interest: ${get('role') || 'No preference'}`,
        '',
        get('message'),
      ];
      const href = `mailto:${email}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(
        bodyLines.join('\n')
      )}`;
      window.location.href = href;
    });
  }
</script>

<style>
  .cform {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .cform__intro {
    font-size: var(--fs-small);
    color: var(--ink-secondary);
  }

  .cform__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-5);
  }

  .cform__field {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .cform__field label {
    font-family: var(--font-ui);
    font-size: var(--fs-label);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--ink-secondary);
  }

  .cform__req {
    color: var(--signal-orange-text);
  }
  .cform__optional {
    color: var(--ink-muted);
    font-weight: var(--fw-regular);
    text-transform: none;
    letter-spacing: 0;
  }

  .cform__field input,
  .cform__field select,
  .cform__field textarea {
    width: 100%;
    padding: var(--space-3) var(--space-4);
    background: var(--surface-page);
    border: var(--border);
    border-radius: var(--radius);
    font-family: var(--font-ui);
    font-size: var(--fs-body);
    color: var(--ink-strong);
  }
  .cform__field textarea {
    resize: vertical;
    min-height: 120px;
  }
  .cform__field input:focus,
  .cform__field select:focus,
  .cform__field textarea:focus {
    outline: 2px solid var(--brand-green);
    outline-offset: 1px;
    border-color: var(--brand-green);
  }

  .cform__help {
    font-size: var(--fs-small);
    color: var(--ink-muted);
  }

  .cform__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-4);
  }
  .cform__fallback {
    font-size: var(--fs-small);
    color: var(--ink-secondary);
  }

  @media (max-width: 600px) {
    .cform__row {
      grid-template-columns: 1fr;
    }
  }
</style>
