---
/**
 * ContactForm — posts natively (no JS required) to the serverless contact
 * endpoint (site.contactFormEndpoint), which forwards the message to the org
 * inbox and 303-redirects back to /contact/thanks or /contact?error=1. The
 * contract lives in docs/architecture/contact-form.md. The `_gotcha` field is a
 * honeypot: visually hidden, humans never fill it, bots that do are dropped.
 */
import Button from '../Button.astro';
import { site } from '@config/site';
import { contact } from '@config/content';

const roleOptions = contact.roles.map((r) => r.name);
---

<div class="cform__error" data-form-error hidden>
  <p>{contact.formErrorNote}</p>
</div>

<form class="cform" action={site.contactFormEndpoint} method="post">
  <p class="cform__intro">{contact.formIntro}</p>

  <p class="cform__gotcha" aria-hidden="true">
    <label for="cf-gotcha">Leave this field empty</label>
    <input id="cf-gotcha" name="_gotcha" type="text" tabindex="-1" autocomplete="off" />
  </p>

  <div class="cform__row">
    <div class="cform__field">
      <label for="cf-name">Name <span class="cform__req" aria-hidden="true">*</span></label>
      <input id="cf-name" name="name" type="text" required autocomplete="name" />
    </div>
    <div class="cform__field">
      <label for="cf-email">Email <span class="cform__req" aria-hidden="true">*</span></label>
      <input id="cf-email" name="email" type="email" required autocomplete="email" />
    </div>
  </div>

  <div class="cform__row">
    <div class="cform__field">
      <label for="cf-callsign">
        Ham call sign <span class="cform__optional">(optional)</span>
      </label>
      <input
        id="cf-callsign"
        name="callsign"
        type="text"
        autocomplete="off"
        spellcheck="false"
        aria-describedby="cf-callsign-help"
      />
      <p id="cf-callsign-help" class="cform__help">If you hold an amateur radio license.</p>
    </div>
    <div class="cform__field">
      <label for="cf-role">Area of interest <span class="cform__optional">(optional)</span></label>
      <select id="cf-role" name="role">
        <option value="">No preference</option>
        {roleOptions.map((r) => <option value={r}>{r}</option>)}
      </select>
    </div>
  </div>

  <div class="cform__field">
    <label for="cf-message"
      >How would you like to help? <span class="cform__req" aria-hidden="true">*</span></label
    >
    <textarea id="cf-message" name="message" rows="5" required></textarea>
  </div>

  <div class="cform__actions">
    <Button variant="primary" type="submit" arrow>Send Message</Button>
    <p class="cform__fallback">
      Prefer to write directly? Email
      <a href={`mailto:${site.email}`}>{site.email}</a>.
    </p>
    {
      site.emailIsPlaceholder && (
        <p class="cform__help">
          Our email inbox is being established — the P.O. Box is the most reliable way to reach us
          right now.
        </p>
      )
    }
  </div>

  <p class="cform__privacy">{contact.formPrivacyNote}</p>
</form>

<script>
  // The endpoint bounces a failed send back to /contact?error=1 — reveal the note.
  if (new URLSearchParams(location.search).has('error')) {
    document.querySelector('[data-form-error]')?.removeAttribute('hidden');
  }
</script>

<style>
  .cform {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .cform__intro {
    font-size: var(--fs-small);
    color: var(--ink-secondary);
  }

  /* Failed-send note (revealed by the ?error=1 script above the form). */
  .cform__error {
    margin-bottom: var(--space-5);
    padding: var(--space-4) var(--space-5);
    background: var(--surface-banner);
    border: var(--border);
    border-left: 3px solid var(--brand-brass);
    font-size: var(--fs-small);
    color: var(--ink-body);
  }

  /* Honeypot — off-screen but focusable-by-bots; never display:none (some bots skip it). */
  .cform__gotcha {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .cform__privacy {
    font-size: var(--fs-small);
    color: var(--ink-muted);
  }

  .cform__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-5);
  }

  .cform__field {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .cform__field label {
    font-family: var(--font-ui);
    font-size: var(--fs-label);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--ink-secondary);
  }

  .cform__req {
    color: var(--ink-secondary);
  }
  .cform__optional {
    color: var(--ink-muted);
    font-weight: var(--fw-regular);
    text-transform: none;
    letter-spacing: 0;
  }

  .cform__field input,
  .cform__field select,
  .cform__field textarea {
    width: 100%;
    padding: var(--space-3) var(--space-4);
    background: var(--surface-page);
    border: var(--border-w) solid var(--line-control);
    border-radius: var(--radius);
    font-family: var(--font-ui);
    font-size: var(--fs-body);
    color: var(--ink-strong);
  }
  .cform__field textarea {
    resize: vertical;
    min-height: 120px;
  }
  .cform__field input:focus,
  .cform__field select:focus,
  .cform__field textarea:focus {
    outline: 2px solid var(--brand-green);
    outline-offset: 1px;
    border-color: var(--brand-green);
  }

  .cform__help {
    font-size: var(--fs-small);
    color: var(--ink-muted);
  }

  .cform__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-4);
  }
  .cform__fallback {
    font-size: var(--fs-small);
    color: var(--ink-secondary);
  }

  @media (max-width: 600px) {
    .cform__row {
      grid-template-columns: 1fr;
    }
  }
</style>
