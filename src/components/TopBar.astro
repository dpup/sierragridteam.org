---
/**
 * TopBar — the operations nav (design-system §6 "Top bar").
 * Brand mark (left, hidden on the homepage where the hero emblem stands in),
 * primary links, a Donate link (orange-accent text), and a live local clock.
 * Sticky, parchment, thin tan bottom rule ("fixed-feel").
 */
import Logo from './Logo.astro';
import LocalClock from './LocalClock.astro';
import Container from './Container.astro';
import { nav, site, donate } from '@config/site';

interface Props {
  /** Hide the visible brand lockup (homepage). A screen-reader home link stays. */
  hideBrand?: boolean;
  /** Current path, to mark the active link. */
  path?: string;
}

const { hideBrand = false, path = '' } = Astro.props;
const isActive = (href: string) => path === href || path === `${href}/`;
---

<header class="topbar">
  <Container wide>
    <div class="topbar__inner">
      <div class="topbar__brand">
        {
          hideBrand ? (
            <a class="sr-only" href="/">
              {site.name} home
            </a>
          ) : (
            <a class="topbar__brandlink" href="/" aria-label={`${site.name} home`}>
              <Logo variant="mark" height={30} />
            </a>
          )
        }
      </div>

      <nav class="topbar__nav" aria-label="Primary">
        <ul class="topbar__links">
          {
            nav.map((item) => (
              <li>
                <a
                  href={item.href}
                  class:list={['topbar__link', { 'is-active': isActive(item.href) }]}
                  aria-current={isActive(item.href) ? 'page' : undefined}
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div class="topbar__actions">
        <a href={donate.href} class="topbar__donate">{donate.label}</a>
        <span class="topbar__clock"><LocalClock /></span>
      </div>
    </div>
  </Container>
</header>

<style>
  .topbar {
    position: sticky;
    top: 0;
    z-index: var(--z-topbar);
    background: color-mix(in srgb, var(--surface-page) 92%, transparent);
    backdrop-filter: saturate(1.1) blur(6px);
    border-bottom: var(--border);
  }

  .topbar__inner {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    min-height: var(--topbar-h);
  }

  .topbar__brand {
    flex: 0 0 auto;
    margin-right: auto;
  }

  .topbar__brandlink {
    display: inline-flex;
    align-items: center;
  }
  .topbar__brandlink:hover {
    text-decoration: none;
  }

  .topbar__nav {
    flex: 0 1 auto;
  }

  .topbar__links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: var(--space-6);
  }

  .topbar__link {
    font-family: var(--font-ui);
    font-size: var(--fs-label);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--ink-secondary);
    padding-block: var(--space-2);
  }

  .topbar__link:hover,
  .topbar__link.is-active {
    color: var(--brand-green);
    text-decoration: none;
  }

  .topbar__link.is-active {
    box-shadow: inset 0 -2px 0 var(--brand-green);
  }

  .topbar__actions {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  /* Donate: an orange-accent text link (not a filled button), styled like the nav
     labels. Uses the AA-compliant small-text orange. The sole sanctioned non-risk
     use of orange (org decision — see CLAUDE.md). */
  .topbar__donate {
    font-family: var(--font-ui);
    font-size: var(--fs-label);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--signal-orange-text);
    padding-block: var(--space-2);
  }
  .topbar__donate:hover {
    color: var(--signal-orange-hover);
    text-decoration: none;
  }

  /* On narrow screens, drop the clock; keep brand + links + the Donate link. */
  @media (max-width: 860px) {
    .topbar__clock {
      display: none;
    }
    .topbar__links {
      gap: var(--space-5);
    }
  }

  /* Very narrow: tighten gaps + tracking so the links + Donate stay on one row. */
  @media (max-width: 480px) {
    .topbar__inner {
      gap: var(--space-3);
    }
    .topbar__links {
      gap: var(--space-3);
    }
    .topbar__link,
    .topbar__donate {
      letter-spacing: 0.08em;
    }
  }

  /* Smallest phones (~360px): step the labels down a size and tighten further. */
  @media (max-width: 400px) {
    .topbar__inner {
      gap: var(--space-2);
    }
    .topbar__links {
      gap: var(--space-2);
    }
    .topbar__link,
    .topbar__donate {
      font-size: var(--fs-micro);
      letter-spacing: 0.06em;
    }
  }
</style>
