---
/**
 * CoverageMap — the homepage hero's town network (corridors + markers + labels).
 *
 * HONESTY RULE (design-system §6): an IDENTITY / coverage visual, NOT live network
 * topology. Towns are placed in true relative geography (src/config/coverage.ts);
 * markers and the corridor links share ONE coordinate system so they stay aligned.
 *
 * The faint grid + topographic contours now live on the Hero band background
 * (full-width), not here. This component stays deliberately thin and quiet:
 * 1px non-scaling strokes, small dots, small labels.
 */
import { towns, corridors, townById } from '@config/coverage';

// viewBox from the town bounds (+ padding) so markers and links share one system.
const xs = towns.map((t) => t.x);
const ys = towns.map((t) => t.y);
const PAD = 34;
const minX = Math.min(...xs) - PAD;
const minY = Math.min(...ys) - PAD;
const w = Math.max(...xs) - Math.min(...xs) + PAD * 2;
const h = Math.max(...ys) - Math.min(...ys) + PAD * 2;
const viewBox = `${minX} ${minY} ${w} ${h}`;

const corridorPath = (ids: readonly string[]) =>
  ids
    .map((id, i) => {
      const t = townById(id);
      return t ? `${i === 0 ? 'M' : 'L'} ${t.x} ${t.y}` : '';
    })
    .join(' ');

const labelSide = (x: number) => (x > minX + w * 0.62 ? 'left' : 'right');

const ariaLabel =
  'Service-area coverage map: Angels Camp, Murphys (headquarters), Arnold, ' +
  'Dorrington, Columbia, and Sonora, linked along the Highway 4 and Highway 49 corridors.';
---

<div class="coverage" role="img" aria-label={ariaLabel}>
  <svg
    class="coverage__svg"
    viewBox={viewBox}
    preserveAspectRatio="xMidYMid meet"
    aria-hidden="true"
  >
    {/* Coverage links along road corridors — true 1px regardless of scale */}
    <g class="coverage__links">
      {
        corridors.map((c) => (
          <path
            d={corridorPath(c.path)}
            class:list={['coverage__link', { 'is-dashed': c.kind === 'dashed' }]}
            vector-effect="non-scaling-stroke"
          />
        ))
      }
    </g>

    {/* Town markers + labels */}
    <g class="coverage__markers">
      {
        towns.map((t, i) => (
          <g
            class={`coverage__marker coverage__marker--${t.role}`}
            transform={`translate(${t.x} ${t.y})`}
          >
            <circle
              class="coverage__ping"
              r="3.4"
              style={`animation-delay:${(i * 0.4).toFixed(2)}s`}
            />
            <circle class="coverage__dot" r="3" vector-effect="non-scaling-stroke" />
            {t.label && (
              <text
                class="coverage__label"
                x={labelSide(t.x) === 'left' ? -5 : 5}
                y="1.2"
                text-anchor={labelSide(t.x) === 'left' ? 'end' : 'start'}
                vector-effect="non-scaling-stroke"
              >
                {t.name}
                {t.role === 'hq' ? ' · HQ' : ''}
              </text>
            )}
          </g>
        ))
      }
    </g>
  </svg>
</div>

<style>
  .coverage {
    width: 100%;
    height: 100%;
    min-height: 300px;
    display: flex;
  }

  .coverage__svg {
    width: 100%;
    height: 100%;
  }

  /* Corridor links — 1px on screen at any width */
  .coverage__link {
    fill: none;
    stroke: var(--brand-green);
    stroke-width: 1;
    stroke-linecap: round;
    stroke-linejoin: round;
    opacity: 0.45;
  }
  .coverage__link.is-dashed {
    stroke: var(--brand-brass);
    stroke-dasharray: 4 5;
    opacity: 0.55;
  }

  .coverage__dot {
    stroke: var(--surface-hero);
    stroke-width: 1.5;
  }
  .coverage__marker--hq .coverage__dot {
    fill: var(--brand-green);
  }
  .coverage__marker--town .coverage__dot {
    fill: var(--brand-brass);
  }
  .coverage__marker--hub .coverage__dot {
    fill: var(--signal-orange);
  }

  .coverage__ping {
    fill: none;
    stroke-width: 1;
    transform-box: fill-box;
    transform-origin: center;
    animation: coverage-ping var(--ping-duration) ease-out infinite;
  }
  .coverage__marker--hq .coverage__ping {
    stroke: var(--brand-green);
  }
  .coverage__marker--town .coverage__ping {
    stroke: var(--brand-brass);
  }
  .coverage__marker--hub .coverage__ping {
    stroke: var(--signal-orange);
  }

  @keyframes coverage-ping {
    0% {
      transform: scale(0.7);
      opacity: 0.6;
    }
    70%,
    100% {
      transform: scale(3);
      opacity: 0;
    }
  }

  .coverage__label {
    font-family: var(--font-ui);
    font-size: 4px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    fill: var(--ink-strong);
    paint-order: stroke;
    stroke: var(--surface-hero);
    stroke-width: 2px;
    stroke-linejoin: round;
  }
  .coverage__marker--hq .coverage__label {
    fill: var(--brand-green);
  }

  @media (prefers-reduced-motion: reduce) {
    .coverage__ping {
      animation: none;
      opacity: 0;
    }
  }
</style>
