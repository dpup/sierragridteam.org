---
/**
 * OperationalStatus — the four operational-status tiles (design-system §7). Relay Sites +
 * Coverage are static owned config. Active Alerts + Fire Weather are LIVE-ONLY: they SSR a
 * muted "—" placeholder and a client island fills them from data.sierragridteam.org on load (and every
 * 5 min). On any failure they stay "—" (an honest "unknown") — never a stale baked value,
 * never a spinner. (It doesn't need /live's full loader; the page isn't gated.)
 */
import Container from '../Container.astro';
import Kicker from '../Kicker.astro';
import StatTile from '../StatTile.astro';
import StatusPill from '../StatusPill.astro';
import { ERSN_API_BASE, NWS_ZONES } from '@lib/ersn';
import { home } from '@config/content';
import { site } from '@config/site';

interface Props {
  // Static owned facts (not from the feed) — the only data this component renders at SSR.
  relaySites: number;
  coverageCounties: number;
}
const { relaySites, coverageCounties } = Astro.props;
---

<section
  class="ops"
  aria-label="Real-time operational status"
  data-ops
  data-api-base={ERSN_API_BASE}
  data-zones={NWS_ZONES.join(',')}
>
  <Container wide>
    <div class="ops__head">
      <Kicker>{home.status.kicker}</Kicker>
      <StatusPill tone="muted" blink={false} data-synced>{home.status.syncing}</StatusPill>
    </div>

    <div class="ops__grid">
      <StatTile
        label="Relay Sites"
        value={`${relaySites} Active`}
        sublabel="Deployed relay sites"
        state="ok-static"
        href="/live"
        key="relay"
      />
      <StatTile
        label="Coverage"
        value={`${coverageCounties} Counties`}
        sublabel={site.counties.join(' & ').replace(/ County/g, '')}
        state="ok-static"
        href="/live"
        key="coverage"
      />
      <StatTile
        label="Active Alerts"
        value="—"
        sublabel="NWS foothill zones"
        state="muted"
        href="/live"
        key="alerts"
      />
      <StatTile
        label="Fire Weather"
        value="—"
        sublabel="Calaveras & Tuolumne"
        state="muted"
        href="/live"
        key="fire"
      />
    </div>
  </Container>
</section>

<script>
  import { formatPtTime } from '@lib/format';

  // Live refresh — upgrades the SSR snapshot when CORS allows; silently keeps it otherwise.
  const REFRESH_MS = 5 * 60 * 1000;
  const section = document.querySelector<HTMLElement>('[data-ops]');
  if (section) {
    const base = section.dataset.apiBase ?? 'https://data.sierragridteam.org/api/v1';
    const zones = section.dataset.zones ?? '';

    const setTile = (key: string, value: string, state: string) => {
      const el = section.querySelector<HTMLElement>(`[data-stat-key="${key}"]`);
      if (!el) return;
      el.dataset.state = state;
      const v = el.querySelector<HTMLElement>('[data-stat-value]');
      if (v) v.textContent = value;
    };

    const alertsUrl = zones ? `${base}/weather/alerts?zones=${zones}` : `${base}/weather/alerts`;

    const refresh = async () => {
      try {
        const [weatherRes, alertsRes] = await Promise.all([
          fetch(`${base}/weather`, { headers: { accept: 'application/json' } }),
          fetch(alertsUrl, { headers: { accept: 'application/json' } }),
        ]);
        if (!weatherRes.ok || !alertsRes.ok) return;
        const weather = (await weatherRes.json()) as {
          fireWeather?: { state?: string };
          lastUpdated?: string;
        };
        const alertsData = (await alertsRes.json()) as {
          alerts?: unknown[];
          lastUpdated?: string;
        };

        const count = (alertsData.alerts ?? []).length;
        setTile('alerts', `${count} Active`, count > 0 ? 'alarm' : 'ok');

        // Authoritative fire-weather state from the feed (FR-3) — never inferred.
        const state = (weather.fireWeather?.state ?? '').toUpperCase();
        const fire =
          state === 'RED_FLAG'
            ? { label: 'Red Flag', state: 'alarm' }
            : state === 'ELEVATED'
              ? { label: 'Elevated', state: 'elevated' }
              : { label: 'Normal', state: 'ok' };
        setTile('fire', fire.label, fire.state);

        const synced = section.querySelector<HTMLElement>('[data-synced] .pill__label');
        const ts = weather.lastUpdated ?? alertsData.lastUpdated;
        if (synced && ts) synced.textContent = `Synced ${formatPtTime(ts)}`;
      } catch {
        // Live-only: there's no baked value to fall back to. Mark the sync state honestly;
        // the Active Alerts / Fire Weather tiles stay on their "—" placeholder (unknown).
        const synced = section.querySelector<HTMLElement>('[data-synced] .pill__label');
        if (synced) synced.textContent = 'Live data unavailable';
      }
    };

    refresh();
    setInterval(refresh, REFRESH_MS);
  }
</script>

<style>
  .ops {
    padding-block: var(--section-y);
    background: var(--surface-page);
  }

  .ops__head {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
  }

  .ops__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4);
  }

  @media (max-width: 900px) {
    .ops__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 520px) {
    .ops__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
