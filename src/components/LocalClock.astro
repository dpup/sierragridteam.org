---
/**
 * LocalClock — live local time for the operations nav. America/Los_Angeles,
 * 24-hour, "PT" suffix. SSR renders the build-time value (no empty flash); the
 * client script keeps it ticking. Deterministic screenshot runs freeze Date so
 * this value is stable (see scripts/screenshots.ts).
 */
import { TIMEZONE } from '@config/site';

// Build-time initial value so the markup is never empty before hydration.
const initial = new Intl.DateTimeFormat('en-GB', {
  timeZone: TIMEZONE,
  hour: '2-digit',
  minute: '2-digit',
  second: '2-digit',
  hour12: false,
}).format(new Date());

interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---

<time class:list={['clock', className]} data-clock aria-label="Current local time, Pacific">
  <span data-clock-value>{initial}</span>
  <span class="clock__tz">PT</span>
</time>

<script>
  const TZ = 'America/Los_Angeles';
  const fmt = new Intl.DateTimeFormat('en-GB', {
    timeZone: TZ,
    hour: '2-digit',
    minute: '2-digit',
    second: '2-digit',
    hour12: false,
  });
  for (const el of document.querySelectorAll('[data-clock]')) {
    const value = el.querySelector('[data-clock-value]');
    if (!value) continue;
    const tick = () => {
      value.textContent = fmt.format(new Date());
    };
    tick();
    setInterval(tick, 1000);
  }
</script>

<style>
  .clock {
    display: inline-flex;
    align-items: baseline;
    gap: 0.35em;
    font-family: var(--font-mono);
    font-size: var(--fs-label);
    letter-spacing: 0.08em;
    color: var(--ink-secondary);
    font-variant-numeric: tabular-nums;
  }

  .clock__tz {
    font-size: var(--fs-micro);
    color: var(--ink-muted);
  }
</style>
