---
/**
 * Container — centered max-width wrapper with the standard page gutters.
 * `wide` switches to the 1320px nav/hero container; default is 1280px content.
 */
interface Props {
  wide?: boolean;
  as?: keyof HTMLElementTagNameMap;
  class?: string;
  id?: string;
}

const { wide = false, as: Tag = 'div', class: className, id } = Astro.props;
---

<Tag class:list={['container', { 'container--wide': wide }, className]} id={id}>
  <slot />
</Tag>

<style>
  .container {
    width: 100%;
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--gutter);
  }

  .container--wide {
    max-width: var(--container-wide);
  }
</style>
