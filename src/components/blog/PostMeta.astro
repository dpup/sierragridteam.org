---
/**
 * PostMeta — the small "date · tag" line above a blog post title. Dates are
 * calendar dates (no timezone), so they format in UTC to avoid off-by-one.
 */
interface Props {
  date: Date;
  /** Last-updated date for a live bulletin. Shown as a distinct "Updated …" time when
   *  later than `date`; omitted otherwise (a normal post reads exactly as before). */
  updatedDate?: Date;
  tag?: string;
  class?: string;
}

const { date, updatedDate, tag, class: className } = Astro.props;

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'UTC',
  });
const iso = (d: Date) => d.toISOString().slice(0, 10);
const showUpdated = updatedDate && updatedDate.valueOf() > date.valueOf();
---

<p class:list={['post-meta', className]}>
  <time datetime={iso(date)}>{fmt(date)}</time>
  {
    showUpdated && (
      <>
        <span class="post-meta__sep" aria-hidden="true">
          ·
        </span>
        {/* "Updated" is real text (not aria-hidden) so the published-vs-updated
          distinction is announced, and the value is its own <time>. */}
        <time class="post-meta__updated" datetime={iso(updatedDate!)}>
          Updated {fmt(updatedDate!)}
        </time>
      </>
    )
  }
  {
    tag && (
      <>
        <span class="post-meta__sep" aria-hidden="true">
          ·
        </span>
        <span class="post-meta__tag">{tag}</span>
      </>
    )
  }
</p>

<style>
  .post-meta {
    font-family: var(--font-ui);
    font-size: var(--fs-label-lg);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--ink-secondary);
  }
  .post-meta__sep {
    margin-inline: var(--space-2);
    color: var(--ink-muted);
  }
  .post-meta__tag {
    color: var(--brand-brass-text);
  }
</style>
