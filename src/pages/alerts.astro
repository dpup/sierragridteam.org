---
import BaseLayout from '@layouts/BaseLayout.astro';
import Section from '@components/Section.astro';
import Kicker from '@components/Kicker.astro';
import AlertsFeed from '@components/alerts/AlertsFeed.astro';
import CurrentConditions from '@components/alerts/CurrentConditions.astro';
import RoadConditions from '@components/alerts/RoadConditions.astro';
import Incidents from '@components/alerts/Incidents.astro';
import { buildSnapshot, splitIncidents } from '@lib/ersn';
import { alerts as copy } from '@config/content';
import { externalLinks } from '@config/site';

const snapshot = await buildSnapshot();
const { inArea, wider } = splitIncidents(snapshot);

const description =
  'Current weather, fire-weather, and road alerts for the Calaveras & Tuolumne foothills, ' +
  'plus live road incidents and emergency resource links.';

const resources = [
  { label: 'CHP Dispatch', desc: 'CAD incidents — Mother Lode', href: externalLinks.chpCad },
  {
    label: 'NWS Sacramento',
    desc: 'Forecasts, watches & warnings',
    href: externalLinks.nwsSacramento,
  },
  { label: 'CAL FIRE', desc: 'Wildfire activity & readiness', href: externalLinks.calFire },
  {
    label: 'USGS Earthquakes',
    desc: 'Recent seismic activity',
    href: externalLinks.usgsEarthquakes,
  },
];
---

<BaseLayout title="Emergency Alerts" description={description} path="/alerts">
  <Section surface="page" labelledby="alerts-title">
    <header class="alerts-head">
      <Kicker>{copy.kicker}</Kicker>
      <h1 id="alerts-title" class="alerts-head__title">{copy.title}</h1>
      <p class="alerts-head__intro">{copy.intro}</p>
    </header>

    {
      !snapshot.live && (
        <p class="alerts-stale" role="note">
          {copy.staleNote}
        </p>
      )
    }

    <div class="alerts-stack">
      <section aria-labelledby="conditions-title">
        <h2 id="conditions-title" class="alerts-h2">{copy.conditionsHeading}</h2>
        <CurrentConditions weather={snapshot.weather} />
      </section>

      <AlertsFeed alerts={snapshot.alerts} />

      <section aria-labelledby="roads-title">
        <h2 id="roads-title" class="alerts-h2">{copy.roadsHeading}</h2>
        <RoadConditions roads={snapshot.roads} />
      </section>

      <section aria-labelledby="incidents-title">
        <h2 id="incidents-title" class="alerts-h2">{copy.incidentsHeading}</h2>
        <p class="alerts-sub">{copy.incidentsNote}</p>
        <Incidents inArea={inArea} wider={wider} />
      </section>

      <section aria-labelledby="resources-title">
        <h2 id="resources-title" class="alerts-h2">{copy.resourcesHeading}</h2>
        <ul class="resources">
          {
            resources.map((r) => (
              <li>
                <a class="resource" href={r.href} target="_blank" rel="noopener external">
                  <span class="resource__label">
                    {r.label}
                    <span class="resource__arrow" aria-hidden="true">
                      &#8599;
                    </span>
                  </span>
                  <span class="resource__desc">{r.desc}</span>
                </a>
              </li>
            ))
          }
        </ul>
      </section>
    </div>
  </Section>
</BaseLayout>

<style>
  .alerts-head {
    max-width: 64ch;
    margin-bottom: var(--space-8);
  }
  .alerts-head__title {
    margin-top: var(--space-3);
    font-size: var(--fs-h2);
  }
  .alerts-head__intro {
    margin-top: var(--space-4);
    font-size: var(--fs-lead);
    line-height: var(--lh-body);
    color: var(--ink-body);
  }

  .alerts-stale {
    margin-bottom: var(--space-7);
    padding: var(--space-4) var(--space-5);
    background: var(--surface-card);
    border: var(--border);
    border-left: 3px solid var(--brand-brass);
    border-radius: var(--radius);
    font-family: var(--font-ui);
    font-size: var(--fs-small);
    color: var(--ink-secondary);
  }

  .alerts-stack {
    display: flex;
    flex-direction: column;
    gap: var(--space-9);
  }

  .alerts-h2 {
    font-size: var(--fs-h3);
    margin-bottom: var(--space-5);
  }
  .alerts-sub {
    margin-top: calc(var(--space-5) * -1 + var(--space-2));
    margin-bottom: var(--space-5);
    font-size: var(--fs-small);
    color: var(--ink-secondary);
  }

  .resources {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4);
  }
  @media (max-width: 900px) {
    .resources {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 480px) {
    .resources {
      grid-template-columns: 1fr;
    }
  }
  .resource {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-5);
    background: var(--surface-card);
    border: var(--border);
    border-radius: var(--radius);
  }
  .resource:hover {
    text-decoration: none;
    border-color: var(--brand-green);
  }
  .resource__label {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: var(--font-ui);
    font-size: var(--fs-label-lg);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--brand-green);
  }
  .resource__desc {
    font-size: var(--fs-small);
    color: var(--ink-secondary);
  }
</style>
