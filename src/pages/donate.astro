---
import BaseLayout from '@layouts/BaseLayout.astro';
import Section from '@components/Section.astro';
import Kicker from '@components/Kicker.astro';
import Card from '@components/Card.astro';
import Callout from '@components/Callout.astro';
import { donate } from '@config/content';
import { site } from '@config/site';

const description =
  'Support S.I.E.R.R.A — your gift funds the solar relays, radios, and training that keep the ' +
  'Calaveras & Tuolumne foothills connected when the grid is down.';

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: `Donate — ${site.name}`,
  url: `${site.url}/donate`,
};
---

<BaseLayout title="Donate" description={description} path="/donate" schema={pageSchema}>
  <Section surface="page" labelledby="donate-title">
    <header class="donate-head">
      <Kicker>{donate.kicker}</Kicker>
      <h1 id="donate-title" class="donate-head__title">{donate.title}</h1>
      <p class="donate-head__intro">{donate.intro}</p>
    </header>
  </Section>

  <Section surface="page" labelledby="ways-title">
    <h2 id="ways-title" class="donate-h2">{donate.waysHeading}</h2>
    <div class="donate-ways">
      {
        donate.ways.map((w) => (
          <Card class="donate-way">
            <div class="donate-way__top">
              <p class="donate-way__name">{w.name}</p>
              {w.status === 'pending' && <span class="donate-way__tag">Coming soon</span>}
            </div>
            <p class="donate-way__desc">{w.desc}</p>
          </Card>
        ))
      }
    </div>

    <div class="donate-tax">
      <Callout accent="brass" heading="Tax status">
        {donate.taxNote}
      </Callout>
    </div>
  </Section>
</BaseLayout>

<style>
  .donate-head {
    max-width: 60ch;
  }
  .donate-head__title {
    margin-top: var(--space-3);
    font-size: var(--fs-h2);
  }
  .donate-head__intro {
    margin-top: var(--space-4);
    font-size: var(--fs-lead);
    line-height: var(--lh-body);
    color: var(--ink-body);
  }

  .donate-h2 {
    font-size: var(--fs-h3);
    margin-bottom: var(--space-5);
  }
  .donate-ways {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
  }
  .donate-way__top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
  }
  .donate-way__name {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: var(--fw-medium);
    color: var(--ink-strong);
  }
  .donate-way__tag {
    flex-shrink: 0;
    font-family: var(--font-ui);
    font-size: var(--fs-micro);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--ink-muted);
  }
  .donate-way__desc {
    font-size: var(--fs-small);
    line-height: var(--lh-body);
    color: var(--ink-body);
  }

  .donate-tax {
    margin-top: var(--space-6);
  }

  @media (max-width: 860px) {
    .donate-ways {
      grid-template-columns: 1fr;
    }
  }
</style>
