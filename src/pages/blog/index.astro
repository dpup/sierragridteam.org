---
/**
 * /blog — the news feed's front page: the most recent posts in full (they run
 * 300–700 words, so a handful reads comfortably), then a pointer to the
 * archive. Posts live in src/content/blog/ (see docs/news-feed-content-brief.md).
 */
import { getCollection, render } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Section from '@components/Section.astro';
import Kicker from '@components/Kicker.astro';
import Button from '@components/Button.astro';
import PostMeta from '@components/blog/PostMeta.astro';
import Prose from '@components/blog/Prose.astro';
import PostNotes from '@components/blog/PostNotes.astro';
import { blog, colophon } from '@config/content';
import { site } from '@config/site';

const description =
  'News and notes from S.I.E.R.R.A — technology, preparedness, and lessons in emergency ' +
  'communications for the Calaveras & Tuolumne foothills.';

const allPosts = await getCollection('blog');
// Order by most-recent activity: a live bulletin's updatedDate bumps it to the top;
// normal posts (no updatedDate) sort by pubDate exactly as before.
const activity = (p: (typeof allPosts)[number]) => (p.data.updatedDate ?? p.data.pubDate).valueOf();
const all = allPosts.sort((a, b) => activity(b) - activity(a));
const recent = all.slice(0, blog.recentCount);
const rendered = await Promise.all(recent.map(async (post) => ({ post, ...(await render(post)) })));

// The desk disclosure renders once at the feed footer (not per stacked post) when any shown
// post is an automated-desk post. (The emergency caveat is global chrome in SiteFooter.)
const feedHasDesk = recent.some((p) => p.data.author === colophon.deskName);

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: `Blog — ${site.name}`,
  url: `${site.url}/blog`,
};
---

<BaseLayout title="Blog" description={description} path="/blog" schema={pageSchema}>
  <Section surface="page" labelledby="blog-title">
    <div class="blog-layout">
      <header class="blog-head">
        <Kicker>{blog.kicker}</Kicker>
        <h1 id="blog-title" class="blog-head__title">{blog.title}</h1>
        <p class="blog-head__intro">{blog.intro}</p>
        {
          all.length > 0 && (
            <div class="blog-head__archive">
              <Button variant="secondary" href="/blog/archive" arrow>
                {blog.archiveLink}
              </Button>
            </div>
          )
        }
      </header>

      <div class="blog-feed">
        {all.length === 0 && <p class="blog-empty">{blog.emptyNote}</p>}
        {
          rendered.map(({ post, Content }) => (
            <article class="blog-post" aria-labelledby={`post-${post.id}`}>
              <PostMeta
                date={post.data.pubDate}
                updatedDate={post.data.updatedDate}
                tag={post.data.tag}
              />
              <h2 id={`post-${post.id}`} class="blog-post__title">
                <a href={`/blog/${post.id}`}>{post.data.title}</a>
              </h2>
              {/* A live bulletin shows only its current-status head in the feed; the full
                timeline is on the permalink. Every other post renders in full as before. */}
              {post.data.summary ? (
                <div class="blog-post__fold">
                  <Prose>
                    <p>{post.data.summary}</p>
                  </Prose>
                  <p class="blog-post__more">
                    <a href={`/blog/${post.id}#timeline`}>
                      Read the full situation
                      <span aria-hidden="true"> →</span>
                    </a>
                  </p>
                </div>
              ) : (
                <Prose>
                  <Content />
                </Prose>
              )}
            </article>
          ))
        }
        <PostNotes desk={feedHasDesk} class="blog-feed__notes" />
      </div>
    </div>
  </Section>
</BaseLayout>

<style>
  /* Header in a sticky left rail, feed on the right — fills the desktop width
     the way the profile pages do. Stacks below 860px. */
  .blog-layout {
    display: grid;
    grid-template-columns: minmax(260px, 340px) 1fr;
    gap: var(--space-9);
    align-items: start;
  }

  .blog-head {
    position: sticky;
    top: calc(var(--topbar-h) + var(--space-5));
  }
  .blog-head__title {
    margin-top: var(--space-3);
    font-size: var(--fs-h2);
  }
  .blog-head__intro {
    margin-top: var(--space-4);
    font-size: var(--fs-lead);
    line-height: var(--lh-body);
    color: var(--ink-body);
  }
  .blog-head__archive {
    margin-top: var(--space-6);
  }

  .blog-empty {
    font-size: var(--fs-lead);
    color: var(--ink-secondary);
  }

  .blog-feed {
    max-width: 66ch;
    min-width: 0;
  }
  .blog-post + .blog-post {
    margin-top: var(--space-8);
    padding-top: var(--space-7);
    border-top: var(--border);
  }
  .blog-post__title {
    margin-top: var(--space-3);
    font-size: var(--fs-h3);
    line-height: var(--lh-heading);
  }
  .blog-post__title a {
    color: var(--ink-strong);
    text-decoration: none;
  }
  .blog-post__title a:hover {
    color: var(--brand-green);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* "Read the full situation →" — the feed fold's link into a live bulletin's timeline. */
  .blog-post__more {
    margin-top: var(--space-4);
    font-family: var(--font-ui);
    font-size: var(--fs-label-lg);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
  }
  .blog-post__more a {
    color: var(--brand-green);
  }
  .blog-post__more a:hover {
    color: var(--brand-green-hover);
    text-decoration: none;
  }

  @media (max-width: 860px) {
    .blog-layout {
      grid-template-columns: 1fr;
      gap: var(--space-7);
    }
    .blog-head {
      position: static;
    }
  }
</style>
