---
import BaseLayout from '@layouts/BaseLayout.astro';
import Section from '@components/Section.astro';
import Kicker from '@components/Kicker.astro';
import StatusPill from '@components/StatusPill.astro';
import StatTile from '@components/StatTile.astro';
import { buildSituationSnapshot } from '@lib/hazards';
import { buildSnapshot } from '@lib/ersn';
import { buildView } from '@lib/live-view';
import { live as copy } from '@config/content';
import { externalLinks, site } from '@config/site';
import '../styles/live.css';

// SSR fallback / no-JS / SEO render from the build-time snapshot. The browser then
// re-fetches info.ersn.net and re-renders these regions live (see the script below),
// so the SAME view-model + render functions produce both passes (src/lib/live-view.ts).
const haz = await buildSituationSnapshot();
const ersn = await buildSnapshot();
const view = buildView(haz, ersn);

const legend = [
  { key: 'town', label: 'Town' },
  { key: 'wildfire', label: 'Wildfire' },
  { key: 'evacuation', label: 'Evacuation' },
  { key: 'incident', label: 'Road incident' },
  { key: 'quake', label: 'Earthquake' },
];

const resources = [
  { label: 'CHP Dispatch', desc: 'CAD incidents — Mother Lode', href: externalLinks.chpCad },
  { label: 'CAL FIRE', desc: 'Wildfire activity & readiness', href: externalLinks.calFire },
  {
    label: 'NWS Sacramento',
    desc: 'Forecasts, watches & warnings',
    href: externalLinks.nwsSacramento,
  },
  {
    label: 'USGS Earthquakes',
    desc: 'Recent seismic activity',
    href: externalLinks.usgsEarthquakes,
  },
];

const description =
  'Live situation map and prioritized alert stream for the Calaveras & Tuolumne foothills — ' +
  'wildfire, evacuation, weather, seismic, and road feeds aggregated from official sources.';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: `${copy.heading} — ${site.name}`,
  url: `${site.url}/live`,
};
---

<BaseLayout title={copy.title} description={description} path="/live" schema={schema}>
  {
    /* Hide the live body + footer and show the loader before the page paints — set here
      (not in deferred JS) so there's no flash of the build-time snapshot. */
  }
  <script is:inline>
    document.documentElement.dataset.liveBoot = 'loading';
  </script>

  <Section surface="page" labelledby="live-title">
    <header class="live-head">
      <Kicker>{copy.kicker}</Kicker>
      <h1 id="live-title" class="live-head__title">{copy.heading}</h1>
      <p class="live-head__intro">{copy.intro}</p>
    </header>

    <div class="live-loader" data-live-loader role="status" aria-live="polite">
      <span class="live-loader__dot" aria-hidden="true"></span>
      <span class="live-loader__text">{copy.loading}</span>
    </div>

    <div class="live-view" data-live-body>
      <p class="live-status">
        <StatusPill tone={view.status.tone} blink={view.status.blink} data-live-pill>
          {view.status.label}
        </StatusPill>
        <span class="live-status__sync"
          ><span data-live-synced>{view.syncedLabel}</span> · {copy.autoRefresh}</span
        >
      </p>

      <p class="live-stale" role="note" data-live-stale hidden={view.live}>{copy.staleNote}</p>

      <div class="live-tiles">
        <StatTile
          label="Wildfires"
          value={view.tiles.wildfires.value}
          sublabel="CAL FIRE"
          state={view.tiles.wildfires.state}
          key="wildfires"
        />
        <StatTile
          label="Evacuations"
          value={view.tiles.evacuations.value}
          sublabel="Cal OES"
          state={view.tiles.evacuations.state}
          key="evacuations"
        />
        <StatTile
          label="Weather Alerts"
          value={view.tiles.weatherAlerts.value}
          sublabel="NWS foothill zones"
          state={view.tiles.weatherAlerts.state}
          key="weatherAlerts"
        />
        <StatTile
          label="Fire Weather"
          value={view.tiles.fireWeather.value}
          sublabel="Calaveras & Tuolumne"
          state={view.tiles.fireWeather.state}
          key="fireWeather"
        />
      </div>

      <aside class="live-evac" aria-label="Evacuation maps">
        <div class="live-evac__text">
          <p class="live-evac__head">{copy.evacHeading}</p>
          <p class="live-evac__note">{copy.evacNote}</p>
        </div>
        <a
          class="live-evac__link"
          href={externalLinks.genasysEvac}
          target="_blank"
          rel="noopener external"
        >
          {copy.evacLinkLabel}
          <span class="live-evac__arrow" aria-hidden="true">&#8599;</span>
        </a>
      </aside>

      <div data-live-weather set:html={view.html.weather} />

      <div class="live-grid">
        <section class="live-grid__map" aria-labelledby="map-title">
          <h2 id="map-title" class="live-h2">{copy.mapHeading}</h2>
          <figure class="hazard-map" data-live-map>
            <div class="hazard-map__canvas" data-map-canvas>
              <p class="hazard-map__fallback" data-map-fallback>
                The live hazard map needs JavaScript and WebGL. Every active hazard is also listed
                in the alert stream beside it.
              </p>
            </div>
            <figcaption class="hazard-map__foot">
              <ul class="hazard-map__legend">
                {
                  legend.map((l) => (
                    <li class="hazard-map__legenditem">
                      <span
                        class:list={['hazard-map__swatch', `hazard-map__swatch--${l.key}`]}
                        aria-hidden="true"
                      />
                      {l.label}
                    </li>
                  ))
                }
              </ul>
              <p class="hazard-map__attrib">
                Basemap &copy; OpenStreetMap, &copy; CARTO · Hazards via info.ersn.net
              </p>
            </figcaption>
            {
              /* Build-time map data, read ONLY by the controller's fetch-failure path to
                still draw the last-known hazards (the success path uses live data). */
            }
            <script
              is:inline
              type="application/json"
              data-map-data
              set:html={JSON.stringify(view.mapData)}
            />
          </figure>
        </section>

        <section class="live-grid__stream" aria-labelledby="stream-title">
          <h2 id="stream-title" class="live-h2">{copy.streamHeading}</h2>
          <div data-live-stream set:html={view.html.stream} />
        </section>
      </div>
    </div>
  </Section>

  <div class="live-view" data-live-body>
    <Section surface="page" labelledby="roads-title">
      <h2 id="roads-title" class="live-h2">{copy.roadsHeading}</h2>
      <div data-live-roads set:html={view.html.roads} />
    </Section>

    <Section surface="page" labelledby="scan-title">
      <h2 id="scan-title" class="live-h2">{copy.scannersHeading}</h2>
      <p class="live-sub">{copy.scannersNote}</p>
      <div data-live-scanners set:html={view.html.scanners} />
    </Section>

    <Section surface="page" labelledby="res-title">
      <h2 id="res-title" class="live-h2">{copy.resourcesHeading}</h2>
      <ul class="live-resources">
        {
          resources.map((r) => (
            <li>
              <a class="resource" href={r.href} target="_blank" rel="noopener external">
                <span class="resource__label">
                  {r.label}
                  <span class="resource__arrow" aria-hidden="true">
                    &#8599;
                  </span>
                </span>
                <span class="resource__desc">{r.desc}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </Section>
  </div>
</BaseLayout>

<script>
  // /live is genuinely live: re-fetch info.ersn.net in the browser, re-render every data
  // region from the SAME view-model the server used, then reveal the page in one paint.
  // On any failure it reveals the build-time snapshot as "last known" — never a spinner.
  import { buildView } from '../lib/live-view';
  import type { LiveView, LiveMapData } from '../lib/live-view';
  import { initHazardMap, type MapHandle } from '../lib/live-map';
  import { ERSN_API_BASE, NWS_ZONES, type ErsnSnapshot } from '../lib/ersn';
  import { HAZARD_AREA, STREAM_LAYERS, type HazardsSnapshot } from '../lib/hazards';

  const REFRESH_MS = 90_000;
  const TIMEOUT_MS = 9_000;

  const root = document.documentElement;
  const figure = document.querySelector<HTMLElement>('[data-live-map]');
  const sigs: Record<string, string> = {};
  let handle: MapHandle | null = null;

  const reveal = () => {
    root.dataset.liveBoot = 'ready';
  };

  function setRegion(sel: string, html: string) {
    const el = document.querySelector<HTMLElement>(sel);
    if (!el || sigs[sel] === html) return;
    sigs[sel] = html;
    el.innerHTML = html;
  }

  function setTile(key: string, t: { value: string; state: string }) {
    const el = document.querySelector<HTMLElement>(`[data-stat-key="${key}"]`);
    if (!el) return;
    el.dataset.state = t.state;
    const v = el.querySelector<HTMLElement>('[data-stat-value]');
    if (v) v.textContent = t.value;
  }

  function applyView(view: LiveView) {
    setRegion('[data-live-weather]', view.html.weather);
    setRegion('[data-live-stream]', view.html.stream);
    setRegion('[data-live-roads]', view.html.roads);
    setRegion('[data-live-scanners]', view.html.scanners);

    setTile('wildfires', view.tiles.wildfires);
    setTile('evacuations', view.tiles.evacuations);
    setTile('weatherAlerts', view.tiles.weatherAlerts);
    setTile('fireWeather', view.tiles.fireWeather);

    const pill = document.querySelector<HTMLElement>('[data-live-pill]');
    if (pill) {
      pill.classList.remove('pill--ok', 'pill--elevated', 'pill--alarm', 'pill--muted');
      pill.classList.add(`pill--${view.status.tone}`);
      pill.classList.toggle('pill--blink', view.status.blink);
      const label = pill.querySelector<HTMLElement>('.pill__label');
      if (label) label.textContent = view.status.label;
    }

    const synced = document.querySelector<HTMLElement>('[data-live-synced]');
    if (synced) synced.textContent = view.syncedLabel;
    const stale = document.querySelector<HTMLElement>('[data-live-stale]');
    if (stale) stale.hidden = view.live;
  }

  // Show the "last known" stale note (used on the fetch-failure path, where we have no view).
  function showStaleNote() {
    const stale = document.querySelector<HTMLElement>('[data-live-stale]');
    if (stale) stale.hidden = false;
  }

  function fallbackMapData(): LiveMapData {
    try {
      const el = figure?.querySelector<HTMLElement>('[data-map-data]');
      return JSON.parse(el?.textContent || '{}') as LiveMapData;
    } catch {
      return {
        towns: { type: 'FeatureCollection', features: [] },
        layers: {},
        bounds: {} as never,
      };
    }
  }

  async function fetchSnapshots(signal: AbortSignal): Promise<{
    haz: HazardsSnapshot;
    ersn: ErsnSnapshot;
  }> {
    const get = async (path: string) => {
      const res = await fetch(`${ERSN_API_BASE}${path}`, {
        headers: { accept: 'application/json' },
        signal,
      });
      if (!res.ok) throw new Error(`${path} → ${res.status}`);
      return res.json();
    };
    const [situation, scanners, roads, weather, alerts, ...layerList] = await Promise.all([
      get(`/situation/${HAZARD_AREA}`),
      get(`/scanners/${HAZARD_AREA}`),
      get('/roads'),
      get('/weather'),
      get(`/weather/alerts?zones=${NWS_ZONES.join(',')}`),
      ...STREAM_LAYERS.map((l) => get(`/hazards/${HAZARD_AREA}/${l}.geojson`)),
    ]);
    const layers: Record<string, unknown> = {};
    STREAM_LAYERS.forEach((l, i) => (layers[l] = layerList[i]));
    const haz = {
      fetchedAt: '',
      live: true,
      area: HAZARD_AREA,
      situation,
      layers,
      scanners,
    } as unknown as HazardsSnapshot;
    const ersn = { fetchedAt: '', live: true, roads, weather, alerts } as unknown as ErsnSnapshot;
    return { haz, ersn };
  }

  async function run(initial: boolean) {
    const ac = new AbortController();
    const timer = setTimeout(() => ac.abort(), TIMEOUT_MS);
    try {
      const { haz, ersn } = await fetchSnapshots(ac.signal);
      clearTimeout(timer);
      // Re-render every region each poll; the per-region sig cache in setRegion() already
      // no-ops unchanged content (and preserves any open <details>), which is the cheap,
      // correct way to avoid redundant work — a feed-timestamp guard would risk dropping
      // independent weather/roads/scanner updates that share the situation timestamp.
      const view = buildView(haz, ersn);
      applyView(view);
      if (initial) {
        reveal();
        requestAnimationFrame(() => {
          if (figure) handle = initHazardMap(figure, view.mapData);
        });
      } else if (handle) {
        handle.update(view.mapData);
      }
    } catch {
      clearTimeout(timer);
      if (initial) {
        // Couldn't refresh — reveal the build-time snapshot, honestly labelled as stale.
        const synced = document.querySelector<HTMLElement>('[data-live-synced]');
        if (synced) synced.textContent = 'Last known';
        showStaleNote();
        reveal();
        requestAnimationFrame(() => {
          if (figure) handle = initHazardMap(figure, fallbackMapData());
        });
      }
      // A periodic refresh that fails leaves the current view untouched.
    }
  }

  run(true);
  setInterval(() => run(false), REFRESH_MS);
</script>

<style>
  .live-head {
    max-width: 70ch;
  }
  .live-head__title {
    margin-top: var(--space-3);
    font-size: var(--fs-h2);
  }
  .live-head__intro {
    margin-top: var(--space-4);
    font-size: var(--fs-lead);
    line-height: var(--lh-body);
    color: var(--ink-body);
  }

  /* Loading affordance — calm pulse, no spinner; honors reduced motion.
     `display` is owned by the boot-gate (:global) rules below so it can be toggled;
     these are only the flex-layout + look properties, applied once it's shown. */
  .live-loader {
    min-height: 48vh;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
  }
  .live-loader__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
    background: var(--brand-brass);
    animation: live-pulse 1.6s ease-in-out infinite;
  }
  .live-loader__text {
    font-family: var(--font-ui);
    font-size: var(--fs-label);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--ink-secondary);
  }
  @keyframes live-pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.3;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .live-loader__dot {
      animation-duration: 3.2s;
    }
  }

  /* Live-status cluster: the status pill sits with the synced/refresh line. */
  .live-status {
    margin-top: var(--space-5);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2) var(--space-4);
  }
  .live-status__sync {
    font-family: var(--font-ui);
    font-size: var(--fs-label);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--ink-muted);
  }

  .live-stale {
    margin-top: var(--space-6);
    padding: var(--space-4) var(--space-5);
    background: var(--surface-card);
    border: var(--border);
    border-left: 3px solid var(--brand-brass);
    border-radius: var(--radius);
    font-family: var(--font-ui);
    font-size: var(--fs-small);
    color: var(--ink-secondary);
  }

  .live-tiles {
    margin-top: var(--space-7);
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4);
  }

  .live-evac {
    margin-top: var(--space-6);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3) var(--space-6);
    padding: var(--space-4) var(--space-5);
    background: var(--surface-card);
    border: var(--border);
    border-left: 3px solid var(--brand-brass);
    border-radius: var(--radius);
  }
  .live-evac__head {
    font-family: var(--font-ui);
    font-size: var(--fs-label);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--brand-brass-text);
  }
  .live-evac__note {
    margin-top: var(--space-1);
    max-width: 68ch;
    font-size: var(--fs-small);
    line-height: var(--lh-body);
    color: var(--ink-secondary);
  }
  .live-evac__link {
    flex-shrink: 0;
    font-family: var(--font-ui);
    font-size: var(--fs-label);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--brand-green);
  }
  .live-evac__link:hover {
    text-decoration: none;
    color: var(--brand-green-hover);
  }

  .live-grid {
    margin-top: var(--space-7);
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: var(--space-7);
    align-items: start;
  }
  .live-h2 {
    font-size: var(--fs-h3);
    margin-bottom: var(--space-5);
  }
  .live-sub {
    margin-top: calc(var(--space-5) * -1 + var(--space-2));
    margin-bottom: var(--space-5);
    font-size: var(--fs-small);
    color: var(--ink-secondary);
  }

  /* Hazard-map frame (the figure is static; MapLibre mounts into the canvas). */
  .hazard-map {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .hazard-map__canvas {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 11;
    min-height: 320px;
    max-height: 440px;
    background: var(--surface-card);
    border: var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .hazard-map__fallback {
    position: absolute;
    inset: 0;
    margin: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-7);
    text-align: center;
    font-size: var(--fs-small);
    color: var(--ink-secondary);
  }
  .hazard-map__foot {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3) var(--space-5);
  }
  .hazard-map__legend {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-4);
  }
  .hazard-map__legenditem {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-ui);
    font-size: var(--fs-micro);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--ink-secondary);
  }
  .hazard-map__swatch {
    width: 10px;
    height: 10px;
    flex-shrink: 0;
    border: 1px solid var(--ink-muted);
  }
  .hazard-map__swatch--town {
    background: color-mix(in srgb, var(--ink-muted) 55%, transparent);
    border-radius: 50%;
    border-color: var(--ink-muted);
  }
  .hazard-map__swatch--wildfire {
    background: color-mix(in srgb, var(--signal-orange) 18%, transparent);
    border-color: var(--signal-orange);
  }
  .hazard-map__swatch--evacuation {
    background: color-mix(in srgb, var(--signal-orange-hover) 16%, transparent);
    border-style: dashed;
    border-color: var(--signal-orange-hover);
  }
  .hazard-map__swatch--incident {
    background: var(--brand-brass);
    border-radius: 50%;
    border-color: var(--brand-brass);
  }
  .hazard-map__swatch--quake {
    background: transparent;
    border-radius: 50%;
    border-color: var(--brand-green);
  }
  .hazard-map__attrib {
    font-family: var(--font-ui);
    font-size: var(--fs-micro);
    color: var(--ink-muted);
  }

  .live-resources {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4);
  }
  .resource {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-5);
    background: var(--surface-card);
    border: var(--border);
    border-radius: var(--radius);
  }
  .resource:hover {
    text-decoration: none;
    border-color: var(--brand-green);
  }
  .resource__label {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: var(--font-ui);
    font-size: var(--fs-label-lg);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--brand-green);
  }
  .resource__desc {
    font-size: var(--fs-small);
    color: var(--ink-secondary);
  }

  @media (max-width: 900px) {
    .live-tiles {
      grid-template-columns: repeat(2, 1fr);
    }
    .live-grid {
      grid-template-columns: 1fr;
    }
    .live-resources {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 480px) {
    .live-tiles,
    .live-resources {
      grid-template-columns: 1fr;
    }
  }
</style>

{/* Boot gate: header + nav stay; the live body and footer wait for the first paint. */}
<style is:global>
  [data-live-loader] {
    display: none;
  }
  html[data-live-boot='loading'] [data-live-body] {
    display: none;
  }
  html[data-live-boot='loading'] [data-live-loader] {
    display: flex;
  }
  /* [data-site-footer] is the hook on SiteFooter.astro's <footer> — keep them in sync. */
  html[data-live-boot='loading'] [data-site-footer] {
    display: none;
  }
</style>
