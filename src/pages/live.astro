---
import BaseLayout from '@layouts/BaseLayout.astro';
import Section from '@components/Section.astro';
import Kicker from '@components/Kicker.astro';
import StatusPill from '@components/StatusPill.astro';
import StatTile from '@components/StatTile.astro';
import { live as copy } from '@config/content';
import { externalLinks, site } from '@config/site';
import '../styles/live.css';

// /live renders ENTIRELY in the browser from the live feed — NO build-time snapshot is
// baked in (a stale "last known" all-clear would be dangerous on a life-safety page). SSR
// is just the static header, an empty skeleton the client fills on a successful fetch, and
// a failure panel (also the no-JS / crawler state) that points at the official sources.

const legend = [
  { key: 'town', label: 'Town' },
  { key: 'wildfire', label: 'Wildfire' },
  { key: 'evacuation', label: 'Evacuation' },
  { key: 'incident', label: 'Road incident' },
  { key: 'quake', label: 'Earthquake' },
];

const resources = [
  { label: 'CHP Dispatch', desc: 'CAD incidents — Mother Lode', href: externalLinks.chpCad },
  { label: 'CAL FIRE', desc: 'Wildfire activity & readiness', href: externalLinks.calFire },
  {
    label: 'NWS Sacramento',
    desc: 'Forecasts, watches & warnings',
    href: externalLinks.nwsSacramento,
  },
  {
    label: 'USGS Earthquakes',
    desc: 'Recent seismic activity',
    href: externalLinks.usgsEarthquakes,
  },
];

// Shown on the failure / no-JS panel — evacuation map first (most critical), then the
// per-domain feeds. (The live body repeats these under "Official sources".)
const failSources = [
  { label: 'Evacuation map (Genasys)', href: externalLinks.genasysEvac },
  ...resources.map((r) => ({ label: r.label, href: r.href })),
];

const description =
  'Live situation map and prioritized alert stream for the Calaveras & Tuolumne foothills — ' +
  'wildfire, evacuation, weather, seismic, and road feeds aggregated from official sources.';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: `${copy.heading} — ${site.name}`,
  url: `${site.url}/live`,
};
---

<BaseLayout title={copy.title} description={description} path="/live" schema={schema}>
  {
    /* Show the loader (and hide the body + failure panel + footer) before the page paints
      — set here, not in deferred JS, so the failure panel never flashes on a normal load. */
  }
  <script is:inline>
    document.documentElement.dataset.liveBoot = 'loading';
  </script>

  <Section surface="page" labelledby="live-title">
    <header class="live-head">
      <Kicker>{copy.kicker}</Kicker>
      <h1 id="live-title" class="live-head__title">{copy.heading}</h1>
      <p class="live-head__intro">{copy.intro}</p>
    </header>

    <div class="live-loader" data-live-loader role="status" aria-live="polite">
      <span class="live-loader__dot" aria-hidden="true"></span>
      <span class="live-loader__text">{copy.loading}</span>
    </div>

    {
      /* Failure / no-JS / crawler state — never stale feed data, just an honest pointer to
        the official sources. Visible by default (no JS) and when the live fetch fails. */
    }
    <section class="live-fail" data-live-fail aria-labelledby="fail-title">
      <h2 id="fail-title" class="live-fail__head">{copy.failHeading}</h2>
      <p class="live-fail__body">{copy.failBody}</p>
      <ul class="live-fail__sources">
        {
          failSources.map((s) => (
            <li>
              <a class="live-fail__link" href={s.href} target="_blank" rel="noopener external">
                {s.label}
                <span class="live-fail__arrow" aria-hidden="true">
                  &#8599;
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </section>

    {/* Live body — an empty skeleton; the client fills every region from the live feed. */}
    <div class="live-view" data-live-body>
      <p class="live-status">
        <StatusPill tone="muted" blink={false} data-live-pill>—</StatusPill>
        <span class="live-status__sync"><span data-live-synced>—</span> · {copy.autoRefresh}</span>
      </p>

      {
        /* The three count tiles link (same-page) down to their detail in the alert stream —
          most useful on mobile, where the list sits well below the fold. The client toggles
          the href off when a tile has nothing to show ("None"/"Unknown"), so it only offers
          the jump when there's actually something there. */
      }
      <div class="live-tiles">
        <StatTile
          label="Wildfires"
          value="—"
          sublabel="CAL FIRE"
          state="muted"
          key="wildfires"
          href="#stream-title"
        />
        <StatTile
          label="Evacuations"
          value="—"
          sublabel="Cal OES"
          state="muted"
          key="evacuations"
          href="#stream-title"
        />
        <StatTile
          label="Weather Alerts"
          value="—"
          sublabel="NWS foothill zones"
          state="muted"
          key="weatherAlerts"
          href="#stream-title"
        />
        <StatTile
          label="Fire Weather"
          value="—"
          sublabel="Calaveras & Tuolumne"
          state="muted"
          key="fireWeather"
        />
      </div>

      <aside class="live-evac" aria-label="Evacuation maps">
        <div class="live-evac__text">
          <p class="live-evac__head">{copy.evacHeading}</p>
          <p class="live-evac__note">{copy.evacNote}</p>
        </div>
        <a
          class="live-evac__link"
          href={externalLinks.genasysEvac}
          target="_blank"
          rel="noopener external"
        >
          {copy.evacLinkLabel}
          <span class="live-evac__arrow" aria-hidden="true">&#8599;</span>
        </a>
      </aside>

      <div data-live-weather></div>

      <div class="live-grid">
        <section class="live-grid__map" aria-labelledby="map-title">
          <h2 id="map-title" class="live-h2">{copy.mapHeading}</h2>
          <figure class="hazard-map" data-live-map>
            <div class="hazard-map__canvas" data-map-canvas>
              <p class="hazard-map__fallback" data-map-fallback>
                The live hazard map needs JavaScript and WebGL. Every active hazard is also listed
                in the alert stream beside it.
              </p>
            </div>
            <figcaption class="hazard-map__foot">
              <ul class="hazard-map__legend">
                {
                  legend.map((l) => (
                    <li class="hazard-map__legenditem">
                      <span
                        class:list={['hazard-map__swatch', `hazard-map__swatch--${l.key}`]}
                        aria-hidden="true"
                      />
                      {l.label}
                    </li>
                  ))
                }
              </ul>
              <p class="hazard-map__attrib">
                Basemap &copy; OpenStreetMap, &copy; CARTO · Hazards via data.sierragridteam.org
              </p>
            </figcaption>
          </figure>
        </section>

        <section class="live-grid__stream" aria-labelledby="stream-title">
          {/* tabindex=-1: the count tiles jump here, so focus lands on the heading too. */}
          <h2 id="stream-title" class="live-h2" tabindex="-1">{copy.streamHeading}</h2>
          <div data-live-stream></div>
        </section>
      </div>
    </div>
  </Section>

  <div class="live-view" data-live-body>
    <Section surface="page" labelledby="roads-title">
      <h2 id="roads-title" class="live-h2">{copy.roadsHeading}</h2>
      <div data-live-roads></div>
    </Section>

    <Section surface="page" labelledby="scan-title">
      <h2 id="scan-title" class="live-h2">{copy.scannersHeading}</h2>
      <p class="live-sub">{copy.scannersNote}</p>
      <div data-live-scanners></div>
    </Section>

    <Section surface="page" labelledby="res-title">
      <h2 id="res-title" class="live-h2">{copy.resourcesHeading}</h2>
      <ul class="live-resources">
        {
          resources.map((r) => (
            <li>
              <a class="resource" href={r.href} target="_blank" rel="noopener external">
                <span class="resource__label">
                  {r.label}
                  <span class="resource__arrow" aria-hidden="true">
                    &#8599;
                  </span>
                </span>
                <span class="resource__desc">{r.desc}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </Section>
  </div>
</BaseLayout>

<script>
  // /live is live-only: re-fetch data.sierragridteam.org in the browser, render every region from the
  // empty skeleton, then reveal in one paint. On the FIRST-load failure it shows the failure
  // panel (official sources) — never a stale build snapshot. A later poll that fails keeps
  // the last LIVE data on screen (its "Synced" stamp shows how fresh that is).
  import { buildView } from '../lib/live-view';
  import type { LiveView } from '../lib/live-view';
  import { initHazardMap, type MapHandle } from '../lib/live-map';
  import { GRID_API_BASE, NWS_ZONES, type GridSnapshot } from '../lib/grid';
  import { HAZARD_AREA, STREAM_LAYERS, type HazardsSnapshot } from '../lib/hazards';

  const REFRESH_MS = 90_000;
  const TIMEOUT_MS = 9_000;

  const root = document.documentElement;
  const figure = document.querySelector<HTMLElement>('[data-live-map]');
  const sigs: Record<string, string> = {};
  let handle: MapHandle | null = null;

  const setBoot = (state: 'ready' | 'failed') => {
    root.dataset.liveBoot = state;
  };

  function setRegion(sel: string, html: string) {
    const el = document.querySelector<HTMLElement>(sel);
    if (!el || sigs[sel] === html) return;
    sigs[sel] = html;
    el.innerHTML = html;
  }

  function setTile(key: string, t: { value: string; state: string; href?: string }) {
    const el = document.querySelector<HTMLElement>(`[data-stat-key="${key}"]`);
    if (!el) return;
    el.dataset.state = t.state;
    const v = el.querySelector<HTMLElement>('[data-stat-value]');
    if (v) v.textContent = t.value;
    // The tile is an <a>; make it a live link only when there's detail to jump to.
    // With no href it stays an inert <a> (not focusable, no hover) — no false affordance.
    if (t.href) {
      el.setAttribute('href', t.href);
      el.classList.add('stat--link');
    } else {
      el.removeAttribute('href');
      el.classList.remove('stat--link');
    }
  }

  function applyView(view: LiveView) {
    setRegion('[data-live-weather]', view.html.weather);
    setRegion('[data-live-stream]', view.html.stream);
    setRegion('[data-live-roads]', view.html.roads);
    setRegion('[data-live-scanners]', view.html.scanners);

    setTile('wildfires', view.tiles.wildfires);
    setTile('evacuations', view.tiles.evacuations);
    setTile('weatherAlerts', view.tiles.weatherAlerts);
    setTile('fireWeather', view.tiles.fireWeather);

    const pill = document.querySelector<HTMLElement>('[data-live-pill]');
    if (pill) {
      pill.classList.remove('pill--ok', 'pill--elevated', 'pill--alarm', 'pill--muted');
      pill.classList.add(`pill--${view.status.tone}`);
      pill.classList.toggle('pill--blink', view.status.blink);
      const label = pill.querySelector<HTMLElement>('.pill__label');
      if (label) label.textContent = view.status.label;
    }

    const synced = document.querySelector<HTMLElement>('[data-live-synced]');
    if (synced) synced.textContent = view.syncedLabel;
  }

  async function fetchSnapshots(signal: AbortSignal): Promise<{
    haz: HazardsSnapshot;
    grid: GridSnapshot;
  }> {
    const get = async (path: string) => {
      const res = await fetch(`${GRID_API_BASE}${path}`, {
        headers: { accept: 'application/json' },
        signal,
      });
      if (!res.ok) throw new Error(`${path} → ${res.status}`);
      return res.json();
    };
    const [situation, scanners, roads, weather, alerts, ...layerList] = await Promise.all([
      get(`/situation/${HAZARD_AREA}`),
      get(`/scanners/${HAZARD_AREA}`),
      get('/roads'),
      get('/weather'),
      get(`/weather/alerts?zones=${NWS_ZONES.join(',')}`),
      ...STREAM_LAYERS.map((l) => get(`/hazards/${HAZARD_AREA}/${l}.geojson`)),
    ]);
    const layers: Record<string, unknown> = {};
    STREAM_LAYERS.forEach((l, i) => (layers[l] = layerList[i]));
    const haz = {
      fetchedAt: '',
      area: HAZARD_AREA,
      situation,
      layers,
      scanners,
    } as unknown as HazardsSnapshot;
    const grid = { fetchedAt: '', roads, weather, alerts } as unknown as GridSnapshot;
    return { haz, grid };
  }

  async function run(initial: boolean) {
    const ac = new AbortController();
    const timer = setTimeout(() => ac.abort(), TIMEOUT_MS);
    try {
      const { haz, grid } = await fetchSnapshots(ac.signal);
      clearTimeout(timer);
      // Re-render every region each poll; the per-region sig cache in setRegion() already
      // no-ops unchanged content (and preserves any open <details>), which is the cheap,
      // correct way to avoid redundant work — a feed-timestamp guard would risk dropping
      // independent weather/roads/scanner updates that share the situation timestamp.
      const view = buildView(haz, grid);
      applyView(view);
      if (initial) {
        setBoot('ready');
        requestAnimationFrame(() => {
          if (figure) handle = initHazardMap(figure, view.mapData);
        });
      } else if (handle) {
        handle.update(view.mapData);
      }
    } catch {
      clearTimeout(timer);
      // No stale cache on /live: on the FIRST-load failure show the honest failure panel
      // (official sources). A later poll that fails just leaves the last LIVE data in place.
      if (initial) setBoot('failed');
    }
  }

  // Hover/focus an alert card → highlight its feature on the map, and mirror the "active"
  // state onto the card. Delegated on the persistent stream container so it survives each
  // poll's innerHTML swap; a no-op when the map is unavailable or the item has no geometry.
  const streamEl = document.querySelector<HTMLElement>('[data-live-stream]');
  if (streamEl) {
    let activeCard: HTMLElement | null = null;
    const activate = (target: EventTarget | null) => {
      const card =
        target instanceof Element
          ? (target.closest('[data-hazard-id]') as HTMLElement | null)
          : null;
      if (card === activeCard) return;
      if (activeCard) activeCard.classList.remove('stream__card--active');
      const matched = handle?.highlight(card?.dataset.hazardId ?? null) ?? false;
      activeCard = matched ? card : null;
      if (matched && card) card.classList.add('stream__card--active');
    };
    streamEl.addEventListener('mouseover', (e) => activate(e.target));
    streamEl.addEventListener('mouseleave', () => activate(null));
    streamEl.addEventListener('focusin', (e) => activate(e.target));
    streamEl.addEventListener('focusout', (e) => {
      // Clear only when focus leaves the stream entirely (not when moving within a card).
      if (!streamEl.contains(e.relatedTarget as Node | null)) activate(null);
    });
  }

  run(true);
  setInterval(() => run(false), REFRESH_MS);
</script>

<style>
  .live-head {
    max-width: 70ch;
  }
  .live-head__title {
    margin-top: var(--space-3);
    font-size: var(--fs-h2);
  }
  .live-head__intro {
    margin-top: var(--space-4);
    font-size: var(--fs-lead);
    line-height: var(--lh-body);
    color: var(--ink-body);
  }

  /* Loading affordance — calm pulse, no spinner; honors reduced motion.
     `display` is owned by the boot-gate (:global) rules below so it can be toggled;
     these are only the flex-layout + look properties, applied once it's shown. */
  .live-loader {
    min-height: 48vh;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
  }
  .live-loader__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
    background: var(--brand-brass);
    animation: live-pulse 1.6s ease-in-out infinite;
  }
  .live-loader__text {
    font-family: var(--font-ui);
    font-size: var(--fs-label);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--ink-secondary);
  }
  @keyframes live-pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.3;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .live-loader__dot {
      animation-duration: 3.2s;
    }
  }

  /* Live-status cluster: the status pill sits with the synced/refresh line. */
  .live-status {
    margin-top: var(--space-5);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2) var(--space-4);
  }
  .live-status__sync {
    font-family: var(--font-ui);
    font-size: var(--fs-label);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--ink-muted);
  }

  /* Failure / no-JS panel — honest "couldn't load, here are the official sources". */
  .live-fail {
    margin-top: var(--space-7);
    max-width: 72ch;
    padding: var(--space-6) var(--space-7);
    background: var(--surface-card);
    border: var(--border);
    border-left: 3px solid var(--brand-brass);
    border-radius: var(--radius);
  }
  .live-fail__head {
    font-size: var(--fs-h3);
  }
  .live-fail__body {
    margin-top: var(--space-3);
    max-width: 60ch;
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    color: var(--ink-body);
  }
  .live-fail__sources {
    margin: var(--space-5) 0 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .live-fail__link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-ui);
    font-size: var(--fs-label-lg);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--brand-green);
  }
  .live-fail__link:hover {
    text-decoration: none;
    color: var(--brand-green-hover);
  }

  .live-tiles {
    margin-top: var(--space-7);
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4);
  }

  .live-evac {
    margin-top: var(--space-6);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3) var(--space-6);
    padding: var(--space-4) var(--space-5);
    background: var(--surface-card);
    border: var(--border);
    border-left: 3px solid var(--brand-brass);
    border-radius: var(--radius);
  }
  .live-evac__head {
    font-family: var(--font-ui);
    font-size: var(--fs-label);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--brand-brass-text);
  }
  .live-evac__note {
    margin-top: var(--space-1);
    max-width: 68ch;
    font-size: var(--fs-small);
    line-height: var(--lh-body);
    color: var(--ink-secondary);
  }
  .live-evac__link {
    flex-shrink: 0;
    font-family: var(--font-ui);
    font-size: var(--fs-label);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--brand-green);
  }
  .live-evac__link:hover {
    text-decoration: none;
    color: var(--brand-green-hover);
  }

  .live-grid {
    margin-top: var(--space-7);
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: var(--space-7);
    align-items: start;
  }
  /* Grid items default to min-width:auto, so the MapLibre canvas's intrinsic width would
     force the column wider than the viewport on mobile. min-width:0 lets the track shrink. */
  .live-grid > * {
    min-width: 0;
  }
  .live-h2 {
    font-size: var(--fs-h3);
    margin-bottom: var(--space-5);
    /* Anchor targets (e.g. the tiles → #stream-title) land clear of the sticky topbar. */
    scroll-margin-top: calc(var(--topbar-h) + var(--space-5));
  }
  /* The stream heading is only a programmatic focus target (tabindex=-1) for the tile jump;
     don't paint a focus ring on it — the ring is for genuinely interactive elements. */
  .live-h2:focus {
    outline: none;
  }
  .live-sub {
    margin-top: calc(var(--space-5) * -1 + var(--space-2));
    margin-bottom: var(--space-5);
    font-size: var(--fs-small);
    color: var(--ink-secondary);
  }

  /* Hazard-map frame (the figure is static; MapLibre mounts into the canvas). */
  .hazard-map {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .hazard-map__canvas {
    position: relative;
    width: 100%;
    min-width: 0;
    max-width: 100%;
    aspect-ratio: 16 / 11;
    min-height: 320px;
    max-height: 440px;
    background: var(--surface-card);
    border: var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .hazard-map__fallback {
    position: absolute;
    inset: 0;
    margin: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-7);
    text-align: center;
    font-size: var(--fs-small);
    color: var(--ink-secondary);
  }
  .hazard-map__foot {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3) var(--space-5);
  }
  .hazard-map__legend {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-4);
  }
  .hazard-map__legenditem {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-ui);
    font-size: var(--fs-micro);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--ink-secondary);
  }
  .hazard-map__swatch {
    width: 10px;
    height: 10px;
    flex-shrink: 0;
    border: 1px solid var(--ink-muted);
  }
  .hazard-map__swatch--town {
    background: color-mix(in srgb, var(--ink-muted) 55%, transparent);
    border-radius: 50%;
    border-color: var(--ink-muted);
  }
  .hazard-map__swatch--wildfire {
    background: color-mix(in srgb, var(--signal-orange) 18%, transparent);
    border-color: var(--signal-orange);
  }
  .hazard-map__swatch--evacuation {
    background: color-mix(in srgb, var(--signal-orange-hover) 16%, transparent);
    border-style: dashed;
    border-color: var(--signal-orange-hover);
  }
  .hazard-map__swatch--incident {
    background: var(--brand-brass);
    border-radius: 50%;
    border-color: var(--brand-brass);
  }
  .hazard-map__swatch--quake {
    background: transparent;
    border-radius: 50%;
    border-color: var(--brand-green);
  }
  .hazard-map__attrib {
    font-family: var(--font-ui);
    font-size: var(--fs-micro);
    color: var(--ink-muted);
  }

  .live-resources {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4);
  }
  .resource {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-5);
    background: var(--surface-card);
    border: var(--border);
    border-radius: var(--radius);
  }
  .resource:hover {
    text-decoration: none;
    border-color: var(--brand-green);
  }
  .resource__label {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: var(--font-ui);
    font-size: var(--fs-label-lg);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--brand-green);
  }
  .resource__desc {
    font-size: var(--fs-small);
    color: var(--ink-secondary);
  }

  @media (max-width: 900px) {
    .live-tiles {
      grid-template-columns: repeat(2, 1fr);
    }
    .live-grid {
      grid-template-columns: 1fr;
    }
    .live-resources {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 480px) {
    .live-tiles,
    .live-resources {
      grid-template-columns: 1fr;
    }
  }
</style>

{
  /* Boot gate. States via data-live-boot: (unset = no-JS/crawler) | loading | ready | failed.
     Defaults (no attr) show the failure panel and hide the loader + body — we never bake
     stale feed data into the page, so "no JS" degrades to the same honest official-sources
     panel as a failed fetch. The header + nav are always present. */
}
<style is:global>
  [data-live-loader] {
    display: none;
  }
  [data-live-body] {
    display: none;
  }

  html[data-live-boot='loading'] [data-live-loader] {
    display: flex;
  }
  html[data-live-boot='loading'] [data-live-fail] {
    display: none;
  }
  /* [data-site-footer] is the hook on SiteFooter.astro's <footer> — keep them in sync. */
  html[data-live-boot='loading'] [data-site-footer] {
    display: none;
  }

  html[data-live-boot='ready'] [data-live-body] {
    display: block;
  }
  html[data-live-boot='ready'] [data-live-fail] {
    display: none;
  }

  /* failed (and no-JS): defaults already hide loader + body and show [data-live-fail]. */
</style>
