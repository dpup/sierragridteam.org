---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/home/Hero.astro';
import OperationalStatus from '@components/home/OperationalStatus.astro';
import Section from '@components/Section.astro';
import SectionHeader from '@components/SectionHeader.astro';
import Kicker from '@components/Kicker.astro';
import DoctrineCard from '@components/DoctrineCard.astro';
import ServiceBanner from '@components/ServiceBanner.astro';
import { operations } from '@config/coverage';
import { home } from '@config/content';
import { site } from '@config/site';

// No build-time feed fetch — the operational-status live tiles are filled client-side
// (only static owned facts are passed in). Nothing stale is ever baked into the page.

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: site.legalName,
  alternateName: site.name,
  url: site.url,
};
---

<BaseLayout
  title="Home"
  description={site.tagline}
  path="/"
  hideBrandInNav
  fullTitle={`${site.name} — ${site.legalName}`}
  schema={websiteSchema}
>
  <Hero />

  <OperationalStatus
    relaySites={operations.relaySitesActive}
    coverageCounties={operations.coverageCounties}
  />

  <Section surface="page" labelledby="mission-title">
    <div class="mission">
      <div class="mission__lead">
        <Kicker>{home.mission.kicker}</Kicker>
        <h2 id="mission-title" class="mission__title">{home.mission.title}</h2>
      </div>
      <p class="mission__body">{home.mission.body}</p>
    </div>
  </Section>

  <Section surface="page" labelledby="doctrine-title">
    <SectionHeader
      kicker={home.doctrine.kicker}
      title={home.doctrine.title}
      headingId="doctrine-title"
    />
    <div class="doctrine-grid">
      {
        home.doctrine.cards.map((c) => (
          <DoctrineCard number={c.number} kicker={c.kicker} title={c.title}>
            {c.body}
          </DoctrineCard>
        ))
      }
    </div>
  </Section>

  <ServiceBanner />
</BaseLayout>

<style>
  .mission {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: var(--space-8);
    align-items: center;
  }
  .mission__title {
    margin-top: var(--space-3);
    font-size: var(--fs-h2);
    max-width: 18ch;
  }
  .mission__body {
    font-size: var(--fs-mission);
    line-height: 1.55;
    color: var(--ink-body);
    max-width: 60ch;
  }

  @media (max-width: 760px) {
    .mission {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }
  }

  .doctrine-grid {
    margin-top: var(--space-7);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-7);
  }

  @media (max-width: 860px) {
    .doctrine-grid {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
  }
</style>
