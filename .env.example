# S.I.E.R.R.A site — environment variables (all OPTIONAL).
# Copy to `.env` for local overrides. The site builds fine with none of these set.

# Override the live data feed base URL (default: https://info.ersn.net/api/v1).
# PUBLIC_ vars are exposed to client-side islands.
PUBLIC_ERSN_API_BASE=https://info.ersn.net/api/v1

# Set to "0" to skip the live build-time data fetch and use the checked-in
# snapshot only (src/data/ersn-snapshot.json). Useful for fully offline builds.
ERSN_FETCH_AT_BUILD=1
