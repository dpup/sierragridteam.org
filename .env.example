# S.I.E.R.R.A site — environment variables (all OPTIONAL).
# Copy to `.env` for local overrides. The site builds fine with none of these set.

# Override the live data feed base URL (default: https://data.sierragridteam.org/api/v1).
# PUBLIC_ vars are exposed to client-side islands.
PUBLIC_ERSN_API_BASE=https://data.sierragridteam.org/api/v1

# Public contact email shown on /contact and in structured data.
# Defaults to info@sierragridteam.org if unset.
PUBLIC_CONTACT_EMAIL=info@sierragridteam.org
